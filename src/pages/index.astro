---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TubesCursor from '../components/TubesCursor.astro';
import PainPoints from '../components/PainPoints.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Process from '../components/Process.astro';
import Reviews from '../components/Reviews.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import BlogPreview from '../components/BlogPreview.astro';
import StickyCTA from '../components/StickyCTA.astro';
import FooterHero from '../components/FooterHero.astro';
import Footer from '../components/Footer.astro';
import TrackingThread from '../components/TrackingThread.astro';
import CaseStudies from '../components/CaseStudies.astro';
---

<BaseLayout
  title="Timito Media — Performance Marketing Agentur aus Österreich"
  description="Google Ads, Server-Side Tracking & Webdesign für KMUs im DACH-Raum. Tracking-First Ansatz: Erst Daten reparieren, dann skalieren. Kostenloses Audit anfragen."
>
  <TubesCursor />
  <Header />
  <TrackingThread />
  <main>
    <!-- Akt 1: Problem erkennen -->
    <Hero />
    <PainPoints />

    <!-- Akt 2: Vertrauen + Lösung -->
    <About />
    <Services />
    <Process />
    <Reviews />
    <CaseStudies />

    <!-- Akt 3: Handlung auslösen -->
    <FAQ />
    <Contact />

    <!-- Nachbrenner -->
    <BlogPreview />
  </main>
  <StickyCTA />
  <FooterHero />
  <Footer />
</BaseLayout>
