    color: 'green',
  },
  {
    num: '/04',
    title: 'Joint Venture',
    text: 'Gemeinsam Märkte erschließen, Produkte entwickeln oder Ressourcen teilen. Für Partner die langfristig denken und echte strategische Tiefe suchen.',
    tags: ['Revenue Share', 'Langfristig', 'Strategisch'],
    color: 'yellow',
  },
];

const reasons = [
  {
    title: 'Tracking-First Expertise',
    text: 'Server-Side Tracking ist unser Kerngeschäft — kein Add-On, kein Randbereich. GTM Server Container, Meta CAPI, Enhanced Conversions, Consent Mode v2.',
    tags: ['GTM Server', 'Meta CAPI', 'Enhanced Conversions', 'Consent Mode v2'],
  },
  {
    title: '100% Kundenschutz',
    text: 'NDA und Kundenschutzvereinbarung zu Beginn jeder Partnerschaft. Wir kontaktieren deine Kunden nie eigenständig und löschen Kundendaten nach Projektende.',
    tags: ['NDA-Standard', 'Keine Direktkontaktierung', 'Datenlöschung'],
  },
  {
    title: 'Direkte Ansprechpartner',
    text: 'Du kommunizierst mit Christina oder Mike — nicht mit einem Account Manager der Entscheidungen erst intern abstimmen muss. Kurze Wege, verbindliche Aussagen.',
    tags: ['Senior-Level', 'Keine Zwischenebene', 'Verbindlich'],
  },
  {
    title: 'DSGVO by Default',
    text: 'Alle Leistungen sind von Grund auf DSGVO-konform. Daten werden auf dem Kundenserver anonymisiert, bevor sie US-Plattformen erreichen.',
    tags: ['Server-Side Anonymisierung', 'Enterprise-ready'],
  },
  {
    title: 'Flexible Kapazität',
    text: 'Kein Mindestvolumen, keine Langzeitverträge, keine Kündigungsfristen. Du nutzt unsere Expertise genau dann wenn du sie brauchst.',
    tags: ['Kein Mindestvolumen', 'Keine Bindung', 'On-demand'],
  },
  {
    title: 'DACH-Marktkenntnis',
    text: 'Österreich, Deutschland, Schweiz — wir kennen die rechtlichen Rahmenbedingungen und die Plattform-Besonderheiten. International arbeiten wir auf Englisch.',
    tags: ['AT', 'DE', 'CH', 'Deutsch & Englisch'],
  },
];

const processSteps = [
  {
    title: 'Erstgespräch — 30 Min, unverbindlich.',
    text: 'Wir lernen uns kennen: Was bietest du an? Wo fehlen dir Ressourcen? Welche Kunden könnten profitieren?',
    deliverable: 'Erste Einschätzung & Modell-Empfehlung',
  },
  {
    title: 'Modell & Konditionen definieren.',
    text: 'White-Label, Referral oder etwas Individuelles? Wir erarbeiten gemeinsam die Rahmenbedingungen — transparent, ohne versteckte Kosten.',
    deliverable: 'Angebot & Konditionen in 48h',
  },
  {
    title: 'Vertragliche Basis schaffen.',
    text: 'NDA, Kundenschutzvereinbarung, Partnerkonditionen. Alles was du brauchst um sicher zu arbeiten — ohne monatelange Vertragsverhandlungen.',
    deliverable: 'NDA & Partnervereinbarung',
  },
  {
    title: 'Pilotprojekt starten.',
    text: 'Wir starten mit einem überschaubaren ersten Projekt. Du siehst wie wir arbeiten — Qualität, Kommunikation, Timing. Kein Risiko, kein langfristiges Commitment.',
    deliverable: 'Fertiges Deliverable mit QA-Dokumentation',
  },
  {
    title: 'Laufende Partnerschaft skalieren.',
    text: 'Hat das Pilotprojekt gepasst? Dann integrieren wir uns in deine Prozesse — mit deinen Tools, deinen Templates, deiner Kommunikationsstruktur.',
    deliverable: 'Skalierbare Partnerschaft mit klaren SLAs',
  },
];

const faqs = [
  {
    question: 'Wie funktioniert White-Label konkret?',
    answer: 'Bei White-Label Services arbeitest du unter deiner eigenen Marke. Wir agieren vollständig im Hintergrund. Reports tragen dein Logo, die Kommunikation läuft über dich, dein Kunde erfährt nie von uns. Standard in jeder Partnerschaft: NDA + Kundenschutzvereinbarung vor dem ersten gemeinsamen Projekt.',
  },
  {
    question: 'Wie ist der Kundenschutz geregelt?',
    answer: '100% Kundenschutz ist Standard, nicht Verhandlungsmasse. Wir unterzeichnen zu Beginn eine NDA und eine Kundenschutzvereinbarung. Wir kontaktieren deine Kunden niemals eigenständig, akquirieren nicht in deinem Bestand und löschen Kundendaten nach Projektende.',
  },
  {
    question: 'Gibt es Mindestvolumen oder Langzeitverträge?',
    answer: 'Nein. Keine Mindestabnahme, keine versteckten Kosten, keine Kündigungsfristen bei Projektarbeit. Du nutzt unsere Expertise genau dann wenn du sie brauchst.',
  },
  {
    question: 'Wie sind die Konditionen für Partner?',
    answer: 'Konditionen besprechen wir im Erstgespräch individuell — abhängig von Modell, Volumen und strategischer Tiefe der Partnerschaft. Wir arbeiten mit transparenten Partner-Preislisten die dir klare Kalkulationsgrundlagen geben.',
  },
  {
    question: 'Welche Services bietet ihr als White-Label an?',
    answer: 'Server-Side Tracking (GTM Server Container, Meta CAPI, Enhanced Conversions, Consent Mode v2), Google Ads (Search, Shopping, Performance Max), Social Ads (Meta, TikTok, LinkedIn, Pinterest), Webdesign (Webflow, Shopify) und Strategie & Beratung. Alle Services können einzeln oder als Bundle gebucht werden.',
  },
  {
    question: 'Wie schnell könnt ihr auf Projektanfragen reagieren?',
    answer: 'Als Partner hast du priorisierten Support. Auf Anfragen reagieren wir in der Regel innerhalb von 24 Stunden. Bei dringenden Projekten können wir oft innerhalb einer Woche starten. Für langfristige Partnerschaften bieten wir reservierte Kapazitäten an.',
  },
  {
    question: 'Wie läuft die Kommunikation während eines Projekts?',
    answer: 'Wir passen uns deinen Prozessen an — ob du Slack, Asana, ClickUp oder E-Mail bevorzugst. Bei White-Label Projekten kommunizieren wir niemals direkt mit dem Endkunden, außer du wünschst es ausdrücklich.',
  },
  {
    question: 'Arbeitet ihr auch mit kleinen Agenturen oder Freelancern?',
    answer: 'Ja. Größe ist kein Kriterium — Qualitätsanspruch und kulturelle Passung schon. Gerade Freelancer und kleine Agenturen profitieren oft am meisten, weil sie ihr Portfolio erweitern können ohne eigenes Personal aufzubauen.',
  },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'B2B Agenturkooperation — Timito Media',
  url: `${siteUrl}/agentur-kooperation`,
  description: 'White-Label & Referral für DACH-Agenturen. Erweitere dein Portfolio ohne Fixkosten, Risiko oder Kundenverlust.',
  publisher: { '@id': `${siteUrl}/#business` },
};
---

<BaseLayout
  title="B2B Agenturkooperation — White-Label & Referral | Timito Media"
  description="White-Label & Referral für DACH-Agenturen. Erweitere dein Portfolio ohne Fixkosten, Risiko oder Kundenverlust. 100% Kundenschutz per NDA."
  canonical={`${siteUrl}/agentur-kooperation`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  </Fragment>

  <Header />

  <main class="b2b-page">
    <!-- Hero -->
    <section class="section b2b__hero">
      <div class="container">
        <SectionLabel text="// B2B Agenturkooperation" />
        <h1 class="reveal">White-Label & Referral für DACH-Agenturen — <span class="text_cyan">Erweitere dein Portfolio ohne Fixkosten, Risiko oder Kundenverlust.</span></h1>
        <p class="b2b__hero-sub reveal">
          Kunden fragen nach Services die du nicht intern abdeckst — Server-Side Tracking, Performance Ads, Webdesign. Wir übernehmen die Execution vollständig unter deiner Marke. 100% Kundenschutz per NDA, keine Langzeitverträge, sofort einsatzbereit.
        </p>
        <div class="b2b__hero-stats">
          {heroStats.map((stat) => (
            <div class="b2b__stat reveal">
              <span class="b2b__stat-num">{stat.num}</span>
              <span class="b2b__stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="section b2b__how">
      <div class="container">
        <SectionLabel text="// So funktioniert's" />
        <h2 class="b2b__section-title reveal">Dein Name. Unsere Execution. Euer Ergebnis.</h2>
        <div class="b2b__how-grid">
          {howItWorks.map((col) => (
            <div class="b2b__how-col reveal">
              <h3 class="b2b__how-heading">{col.col}</h3>
              <ul class="b2b__how-list">
                {col.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <div class="b2b__how-badges reveal">
          <span class="b2b__badge">100% Kundenschutz per NDA</span>
          <span class="b2b__badge">White-Label Reports mit deinem Logo</span>
        </div>
      </div>
    </section>

    <!-- Problems -->
    <section class="section b2b__problems">
      <div class="container">
        <SectionLabel text="// Das Problem" />
        <h2 class="b2b__section-title reveal">Warum Agenturen Kapazitäten auslagern —<span class="text_cyan"> und warum das Risiko nicht bei dir liegen sollte.</span></h2>
        <div class="b2b__problem-grid">
          {problems.map((p) => (
            <div class="b2b__problem-card reveal">
              <div class="b2b__problem-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d={p.icon} />
                </svg>
              </div>
              <span class="b2b__problem-num">{p.num}</span>
              <h3>{p.title}</h3>
              <p>{p.text}</p>
            </div>
          ))}
        </div>
        <div class="b2b__solution-card reveal">
          <p><strong>Die Lösung:</strong> Expertise on-demand, sofort einsatzbereit, NDA-geschützt. Dein Portfolio wächst — ohne dass dein Risiko es tut.</p>
        </div>
      </div>
    </section>

    <!-- Cooperation Models -->
    <section class="section b2b__models">
      <div class="container">
        <SectionLabel text="// Kooperationsmodelle" />
        <h2 class="b2b__section-title reveal">Vier Modelle. <span class="text_cyan">Passend für jedes Bedürfniss.</span></h2>
        <p class="b2b__section-sub reveal">Ob du einmalige Kapazität brauchst oder einen langfristigen strategischen Partner — wir passen uns deinem Modell an, nicht umgekehrt.</p>
        <div class="b2b__model-grid">
          {models.map((m) => (
            <div class={`b2b__model-card b2b__model-card--${m.color} reveal`}>
              <span class="b2b__model-num">{m.num}</span>
              <h3>{m.title}</h3>
              <p>{m.text}</p>
              <div class="b2b__model-tags">
                {m.tags.map((tag) => (
                  <span class={`b2b__model-tag b2b__model-tag--${m.color}`}>{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why Timito -->
    <section class="section b2b__why">
      <div class="container">
        <SectionLabel text="// Warum Timito" />
        <h2 class="b2b__section-title reveal">Sechs Gründe warum Partner bei uns bleiben.</h2>
        <div class="b2b__reason-grid">
          {reasons.map((r) => (
            <div class="b2b__reason-card reveal">
              <h3>{r.title}</h3>
              <p>{r.text}</p>
              <div class="b2b__reason-tags">
                {r.tags.map((tag) => (
                  <span class="b2b__reason-tag">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process Timeline -->
    <ProcessTimeline
      sectionTitle="Von der Anfrage zum ersten gemeinsamen Projekt."
      steps={processSteps}
      colorRGB="0, 212, 255"
    />

    <!-- FAQ -->
    <section class="section b2b__faq">
      <div class="container">
        <SectionLabel text="// FAQ" />
        <h2 class="b2b__section-title reveal">Häufige Fragen zur Partnerschaft.</h2>
        <div class="faq__list" data-faq-group>
          {faqs.map((faq, i) => (
            <div class="faq__item reveal">
              <button
                class="faq__trigger"
                type="button"
                aria-expanded="false"
                aria-controls={`b2b-faq-${i}`}
              >
                <span class="faq__num">/{String(i + 1).padStart(2, '0')}</span>
                <span class="faq__question">{faq.question}</span>
                <span class="faq__toggle" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 9l6 6 6-6" />
                  </svg>
                </span>
              </button>
              <div class="faq__panel" id={`b2b-faq-${i}`}>
                <div>
                  <div class="faq__answer">
                    <p>{faq.answer}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact Funnel -->
    <Contact />
  </main>

  <Footer />
</BaseLayout>

<script>
  (function () {
    const groups = document.querySelectorAll('[data-faq-group]');
    groups.forEach((group) => {
      const items = group.querySelectorAll('.faq__item');

      function toggle(item: Element) {
        const isOpen = item.classList.contains('is-open');
        items.forEach((i) => {
          i.classList.remove('is-open');
          i.querySelector('.faq__trigger')?.setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('is-open');
          item.querySelector('.faq__trigger')?.setAttribute('aria-expanded', 'true');
        }
      }

      items.forEach((item) => {
        const trigger = item.querySelector('.faq__trigger');
        if (!trigger) return;
        trigger.addEventListener('click', () => toggle(item));
      });
    });
  })();
</script>

<style>
  /* ===== HERO ===== */
  .b2b__hero {
    padding-top: clamp(8rem, 16vw, 12rem);
    padding-bottom: 0;
  }

  .b2b__hero h1 {
    font: 800 clamp(2rem, 4.5vw, 3.5rem)/1.12 var(--font-heading);
    letter-spacing: -0.03em;
    max-width: 820px;
    margin-bottom: 1.25rem;
  }

  .b2b__hero-sub {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    line-height: 1.8;
    max-width: 700px;
    margin-bottom: 2.5rem;
  }

  .b2b__hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .b2b__stat {
    padding: 1.5rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    text-align: center;
  }

  .b2b__stat-num {
    display: block;
    font: 800 clamp(1.5rem, 3vw, 2.25rem)/1 var(--font-heading);
    color: var(--accent-cyan);
    margin-bottom: 0.5rem;
  }

  .b2b__stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  /* ===== SHARED SECTION STYLES ===== */
  .b2b__section-title {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    margin-bottom: 1rem;
    max-width: 800px;
    color: var(--text-primary);
  }

  .b2b__section-sub {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 2.5rem;
  }

  /* ===== HOW IT WORKS ===== */
  .b2b__how .b2b__section-title {
    margin-bottom: 2.5rem;
  }

  .b2b__how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .b2b__how-col {
    padding: 2rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
  }

  .b2b__how-heading {
    font: 600 0.75rem/1 var(--font-mono);
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.25rem;
  }

  .b2b__how-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .b2b__how-list li {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    padding-left: 1rem;
    position: relative;
  }

  .b2b__how-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent-cyan);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .b2b__how-badges {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .b2b__badge {
    font: 500 0.75rem/1 var(--font-mono);
    color: var(--accent-cyan);
    padding: 0.5rem 1rem;
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 999px;
    background: rgba(0, 212, 255, 0.06);
  }

  /* ===== PROBLEMS ===== */
  .b2b__problems .b2b__section-title {
    margin-bottom: 2.5rem;
  }

  .b2b__problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .b2b__problem-card {
    padding: 2rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    transition: border-color var(--duration) var(--ease);
  }

  .b2b__problem-card:hover {
    border-color: rgba(255, 45, 120, 0.2);
  }

  .b2b__problem-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
