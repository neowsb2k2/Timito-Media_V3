---
/**
 * agentur-kooperation.astro
 * B2B partnership page — White-Label & Referral for DACH agencies.
 * Cooperation models, process, FAQ, and contact funnel.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Contact from '../components/Contact.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import SectionLabel from '../components/SectionLabel.astro';

const siteUrl = 'https://timito-media.at';

const heroStats = [
  { num: '3', label: 'Kooperationsmodelle' },
  { num: '100%', label: 'Kundenschutz per NDA' },
  { num: 'DACH', label: 'Marktfokus AT · DE · CH' },
  { num: '24h', label: 'Reaktionszeit als Partner' },
];

const howItWorks = [
  { col: 'Deine Agentur', items: ['Kundenbeziehung', 'Briefing & Sales', 'Abrechnung'] },
  { col: 'Timito Media', items: ['Execution & Delivery', 'Tracking, Ads, Design', 'NDA-geschützt'] },
  { col: 'Ergebnis', items: ['Zufriedene Kunden', 'Wiederholungsaufträge', 'Deine Marge'] },
];

const problems = [
  {
    num: '/01',
    title: 'Unerfüllte Kundenanfragen',
    text: 'Kunden fragen nach Services die du nicht hast. Tracking-Anfragen, Ads-Management, technische Implementierungen — jedes abgelehnte Projekt ist verlorener Umsatz. Oft wandert der Kunde komplett zur Full-Service-Konkurrenz.',
    icon: 'M12 9v2m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
