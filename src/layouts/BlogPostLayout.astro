---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Contact from '../components/Contact.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AuthorBox from '../components/AuthorBox.astro';
import ShareLinks from '../components/ShareLinks.astro';
import TableOfContents from '../components/TableOfContents.astro';
import SectionLabel from '../components/SectionLabel.astro';
import HeroBackground from '../components/HeroBackground.astro';

interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  author: string;
  publishDate: Date;
  readTime: string;
  cover?: ImageMetadata;
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const {
  title,
  description,
  slug,
  category,
  author,
  publishDate,
  readTime,
  cover,
  headings,
} = Astro.props;

const siteUrl = 'https://timito-media.at';
const canonical = `${siteUrl}/blog/${slug}`;
const ogImage = cover ? undefined : '/assets/images/og-image.webp';

const formattedDate = publishDate.toLocaleDateString('de-AT', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const categoryColorMap: Record<string, string> = {
  Tracking: '5, 223, 114',
  'Google Ads': '0, 212, 255',
  'Social Ads': '255, 45, 120',
  Webdesign: '255, 214, 0',
  Strategie: '168, 85, 247',
};

const rgb = categoryColorMap[category] || '0, 212, 255';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: category },
];

// JSON-LD: BlogPosting
const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  url: canonical,
  datePublished: publishDate.toISOString(),
  author: {
    '@type': 'Person',
    name: author,
    url: `${siteUrl}/#${author.toLowerCase()}`,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Timito Media',
    url: siteUrl,
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  inLanguage: 'de-AT',
};

// JSON-LD: BreadcrumbList
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
    { '@type': 'ListItem', position: 3, name: category, item: canonical },
  ],
};
---

<BaseLayout
  title={`${title} — Timito Media`}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
>
  <Fragment slot="head">
    <!-- OG: article type -->
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={publishDate.toISOString()} />
    <meta property="article:author" content={author} />
    <meta property="article:section" content={category} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!-- Category accent color override -->
    <style is:inline set:html={`:root {
      --cat-rgb: ${rgb};
    }`} />
  </Fragment>

  <Header />
  <main class="blog-post">
    <!-- Hero: full width -->
    <section class="blog-post__hero section">
      <HeroBackground />
      <div class="container">
        <Breadcrumbs items={breadcrumbItems} />
        <SectionLabel text={category} />

        <h1 class="blog-post__title">{title}</h1>

        {description && (
          <p class="blog-post__lead">{description}</p>
        )}

        <div class="blog-post__meta">
          <span class="blog-post__author">{author}</span>
          <span class="blog-post__divider">·</span>
          <time datetime={publishDate.toISOString()}>{formattedDate}</time>
          <span class="blog-post__divider">·</span>
          <span>{readTime} Lesezeit</span>
        </div>

        {cover && (
          <div class="blog-post__cover">
            <Image src={cover} alt={title} width={960} />
          </div>
        )}
      </div>
    </section>

    <!-- Two-column layout -->
    <div class="blog-post__body container">
      <!-- Sidebar (desktop only) -->
      <aside class="blog-post__sidebar">
        <div class="blog-post__sidebar-sticky">
          <TableOfContents headings={headings} readTime={readTime} />
          <div class="blog-post__sidebar-share">
            <ShareLinks url={canonical} title={title} />
          </div>
        </div>
      </aside>

      <!-- Article content -->
      <article class="blog-post__content">
        <slot />

        <AuthorBox authorKey={author} />

        <!-- Mobile share links -->
        <div class="blog-post__mobile-share">
          <ShareLinks url={canonical} title={title} />
        </div>

        <!-- Navigation links -->
        <div class="blog-post__footer">
          <a href="/blog" class="blog-post__back">&larr; Alle Artikel</a>
          <a href="#kontakt" class="blog-post__cta">Kostenloses Audit anfragen &rarr;</a>
        </div>
      </article>
    </div>

    <Contact />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .blog-post__hero {
    position: relative;
    padding-bottom: 0 !important;
  }

  .blog-post__hero > :global(.container) {
    position: relative;
    z-index: 2;
  }

  .blog-post__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .blog-post__lead {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 680px;
    margin-bottom: 1.5rem;
  }

  .blog-post__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .blog-post__author {
    color: var(--accent-cyan);
  }

  .blog-post__divider {
    color: var(--text-muted);
  }

  .blog-post__cover {
    margin-bottom: 0;
    border-radius: var(--radius);
    overflow: hidden;
  }

  .blog-post__cover :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius);
  }

  /* ── Two-column body ── */
  .blog-post__body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-top: 1rem;
    padding-bottom: 3rem;
  }

  @media (min-width: 1024px) {
    .blog-post__body {
      grid-template-columns: 240px 1fr;
      gap: 4rem;
    }
  }

  /* ── Sidebar ── */
  .blog-post__sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .blog-post__sidebar {
      display: block;
    }
  }

  .blog-post__sidebar-sticky {
    position: sticky;
    top: 100px;
  }

  .blog-post__sidebar-share {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--glass-border);
  }

  /* ── Mobile share ── */
  .blog-post__mobile-share {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  @media (min-width: 1024px) {
    .blog-post__mobile-share {
      display: none;
    }
  }

  /* ── Article content typography ── */
  .blog-post__content {
    line-height: 1.8;
    color: var(--text-secondary);
    min-width: 0;
  }

  .blog-post__content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-post__content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-post__content :global(p) {
    margin-bottom: 1.5rem;
    max-width: none;
  }

  .blog-post__content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .blog-post__content :global(a) {
    color: var(--accent-cyan);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-post__content :global(ul),
  .blog-post__content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .blog-post__content :global(li) {
    margin-bottom: 0.5rem;
  }

  .blog-post__content :global(blockquote) {
    border-left: 3px solid var(--accent-cyan);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--text-primary);
  }

  .blog-post__content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--bg-card);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    color: var(--accent-cyan);
  }

  .blog-post__content :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .blog-post__content :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .blog-post__content :global(hr) {
    border: none;
    height: 1px;
    background: var(--border);
    margin: 2.5rem 0;
  }

  .blog-post__content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius);
    margin-block: 1.5rem;
  }

  .blog-post__content :global(table) {
    width: 100%;
    margin-bottom: 1.5rem;
    border-collapse: collapse;
  }

  .blog-post__content :global(th),
  .blog-post__content :global(td) {
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    text-align: left;
    font-size: 0.9rem;
  }

  .blog-post__content :global(th) {
    background: var(--bg-card);
    color: var(--text-primary);
    font-weight: 600;
  }

  /* ── Footer nav ── */
  .blog-post__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .blog-post__back {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .blog-post__back:hover {
    color: var(--text-secondary);
  }

  .blog-post__cta {
    color: var(--accent-cyan);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .blog-post__cta:hover {
    text-decoration: underline;
  }
</style>
