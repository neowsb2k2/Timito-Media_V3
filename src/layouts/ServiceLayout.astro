---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrackingThread from '../components/TrackingThread.astro';
import StickyCTA from '../components/StickyCTA.astro';
import '../styles/service-page.css';

interface Props {
  title: string;
  description: string;
  faqs: Array<{ question: string; answer: string }>;
  slug: string;
  serviceName: string;
  colorRGB?: string;
}

const { title, description, faqs, slug, serviceName, colorRGB } = Astro.props;
const siteUrl = 'https://timito-media.at';
const canonical = `${siteUrl}/leistungen/${slug}`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: serviceName,
  provider: { '@id': `${siteUrl}/#business` },
  areaServed: ['AT', 'DE', 'CH'],
  url: canonical,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Leistungen', item: `${siteUrl}/leistungen` },
    { '@type': 'ListItem', position: 3, name: serviceName, item: canonical },
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {colorRGB && (
      <style is:inline set:html={`:root {
        --accent-cyan: rgb(${colorRGB}) !important;
        --glow-cyan: 0 0 20px rgba(${colorRGB}, 0.35) !important;
      }
      @keyframes ctaPulse {
        0%, 100% { box-shadow: 0 0 20px rgba(${colorRGB}, 0.2); }
        50% { box-shadow: 0 0 35px rgba(${colorRGB}, 0.35); }
      }`} />
    )}
  </Fragment>

  <Header />
  <TrackingThread />
  <main id="main-content">
    <slot />
  </main>
  <StickyCTA colorRGB={colorRGB} />
  <Footer />
</BaseLayout>
