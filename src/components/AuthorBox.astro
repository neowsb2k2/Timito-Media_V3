---
import { authors } from '../data/authors';

interface Props {
  authorKey: string;
}

const { authorKey } = Astro.props;
const author = authors[authorKey];
---

{author && (
  <div class="author-box">
    <div class="author-box__avatar" aria-hidden="true">
      {author.initial}
    </div>
    <div class="author-box__info">
      <span class="author-box__name">{author.name}</span>
      <span class="author-box__role">{author.role}</span>
      <p class="author-box__bio">{author.bio}</p>
    </div>
  </div>
)}

<style>
  .author-box {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.5rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    margin-top: 3rem;
  }

  .author-box__avatar {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(0, 212, 255, 0.1);
    border: 1px solid rgba(0, 212, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font: 600 1.1rem/1 var(--font-heading);
    color: var(--accent-cyan);
  }

  .author-box__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .author-box__name {
    font: 600 0.95rem/1.3 var(--font-body);
    color: var(--text-primary);
  }

  .author-box__role {
    font: 500 0.75rem/1 var(--font-mono);
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .author-box__bio {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-top: 0.5rem;
    max-width: none;
  }
</style>
