---
/**
 * Logo.astro
 * Inline SVG logo — brackets and "PERFORMANCE" text adapt
 * to --accent-cyan (overridden per service page).
 */
interface Props {
  class?: string;
  height?: number;
}

const { class: className, height = 32 } = Astro.props;
---

<svg
  class:list={['logo-svg', className]}
  viewBox="0 0 294.65 63.46"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Timito Media"
  role="img"
  style={`height: ${height}px; width: auto;`}
>
  <!-- TIMITO text -->
  <g class="logo-svg__text">
    <rect x="11.6" width="241.54" height="62.22" style="fill: none;" />
    <path d="M21,13.51h38.47v11.09H21v-11.09ZM34.02,18.86h12.44v30.81h-12.44v-30.81Z" />
    <path d="M63.38,13.51h12.44v36.16h-12.44V13.51Z" />
    <path d="M137.29,13.51v36.16h-11.81v-31.48l2.27.29-12.15,31.19h-12.29l-12.15-31.05,2.27-.34v31.39h-11.81V13.51h19.24l10.8,29.46h-4.29l10.7-29.46h19.24Z" />
    <path d="M143.07,13.51h12.44v36.16h-12.44V13.51Z" />
    <path d="M159.42,13.51h38.47v11.09h-38.47v-11.09ZM172.44,18.86h12.44v30.81h-12.44v-30.81Z" />
    <path d="M221.23,50.54c-4.4,0-8.25-.79-11.55-2.36-3.3-1.58-5.86-3.79-7.69-6.63s-2.75-6.16-2.75-9.96.92-7.11,2.75-9.96c1.83-2.84,4.39-5.05,7.69-6.63,3.29-1.57,7.14-2.36,11.55-2.36s8.25.79,11.55,2.36c3.29,1.58,5.86,3.79,7.69,6.63,1.83,2.84,2.75,6.16,2.75,9.96s-.92,7.11-2.75,9.96c-1.83,2.84-4.4,5.05-7.69,6.63-3.29,1.57-7.14,2.36-11.55,2.36ZM221.23,39.45c1.96,0,3.65-.31,5.06-.94,1.41-.63,2.5-1.53,3.25-2.7.75-1.17,1.13-2.58,1.13-4.22s-.38-3.04-1.13-4.22c-.76-1.17-1.84-2.07-3.25-2.7-1.42-.63-3.1-.94-5.06-.94s-3.65.31-5.06.94c-1.42.63-2.5,1.53-3.25,2.7-.75,1.17-1.13,2.58-1.13,4.22s.38,3.05,1.13,4.22c.75,1.17,1.84,2.07,3.25,2.7,1.41.63,3.1.94,5.06.94Z" />
  </g>
  <!-- Left bracket [ -->
  <polygon class="logo-svg__bracket" points="18.86 11.95 18.86 5.07 0 5.07 0 10.88 0 11.95 0 50.27 0 50.77 0 57.14 18.86 57.14 18.86 50.27 6.87 50.27 6.87 11.95 18.86 11.95" />
  <!-- Right bracket ] -->
  <polygon class="logo-svg__bracket" points="243.21 50.27 243.21 57.14 262.07 57.14 262.07 51.33 262.07 50.27 262.07 11.95 262.07 11.45 262.07 5.07 243.21 5.07 243.21 11.95 255.2 11.95 255.2 50.27 243.21 50.27" />
  <!-- PERFORMANCE side text -->
  <g class="logo-svg__accent">
    <rect x="277.74" y="0" width="15.95" height="62.22" style="fill: none;" />
    <path d="M280.86,44.27h9.99v3.26h-8.69l.08-.63,8.61,3.36v3.39l-8.57,3.36-.09-.63h8.67v3.26h-9.99v-5.31l8.13-2.98v1.18l-8.13-2.96v-5.31Z" />
    <path d="M285.85,38.93l3.71.61-1.44,1.3v-7.58h2.72v9.67l-4.99-.73-4.99.73v-9.6h2.72v7.51l-1.44-1.3,3.71-.61ZM284.67,33.76h2.37v7.52h-2.37v-7.52Z" />
    <path d="M280.86,26.56c0-1.22.21-2.28.62-3.19s.99-1.62,1.74-2.12c.75-.51,1.62-.76,2.64-.76s1.88.25,2.63.76,1.33,1.21,1.74,2.12.62,1.97.62,3.19v5.3h-9.99v-5.3ZM289.31,28.45l-1.53,1.54v-3.7c0-.49-.08-.91-.23-1.26s-.38-.62-.67-.81c-.29-.19-.63-.28-1.03-.28s-.75.09-1.04.28c-.28.19-.5.46-.66.81s-.23.77-.23,1.26v3.7l-1.53-1.54h6.92Z" />
    <path d="M280.86,19.27v-3.44h9.99v3.44h-9.99Z" />
    <path d="M280.86,6.11l9.99-4.38v3.66l-8.47,3.45v-.88l8.47,3.45v3.66l-9.99-4.38v-4.58ZM289.17,11.86h-2.73v-6.8h2.73v6.8Z" />
  </g>
</svg>

<style>
  .logo-svg {
    display: block;
  }

  .logo-svg__text {
    fill: var(--text-primary, #fff);
  }

  .logo-svg__bracket,
  .logo-svg__accent {
    fill: var(--accent-cyan, #00d4ff);
    transition: fill 0.3s ease;
  }
</style>
