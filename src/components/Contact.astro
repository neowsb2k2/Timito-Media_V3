---
import SectionLabel from './SectionLabel.astro';
import Terminal from './Terminal.astro';
import SplitWords from './SplitWords.astro';
---

<section id="kontakt" class="section contact">
  <div class="contact__glow contact__glow--cyan" aria-hidden="true"></div>
  <div class="contact__glow contact__glow--purple" aria-hidden="true"></div>
  <div class="container">
    <div class="contact__grid">
      <!-- Left: Content -->
      <div class="contact__content reveal">
        <SectionLabel text="Strategiegespräch" />
        <h2 class="giant-title headline-reveal">
          <span class="h-line" style="overflow:hidden"><SplitWords text="Bereit für ein" /></span>
          <span class="h-line" style="overflow:hidden"><SplitWords text="Gespräch auf" /></span>
          <span class="h-line line-accent" style="overflow:hidden"><SplitWords text="Augenhöhe?" /></span>
        </h2>
        <p class="contact__sub">Wir nehmen uns 30 Minuten für eine ehrliche Analyse deiner Situation. Kein Pitch. Keine Unverbindlichkeit. Nur ein klares Bild davon, was möglich ist — und was es braucht.</p>

        <ul class="contact__guarantees">
          <li><span class="check">✓</span> Qualifiziertes Erstgespräch</li>
          <li><span class="check">✓</span> Konkrete Quick-Wins – auch wenn wir nicht zusammenarbeiten</li>
          <li><span class="check">✓</span> Direkt mit Christina oder Mike – kein Sales-Team</li>
          <li><span class="check">✓</span> 30 Minuten – respektvoll mit deiner Zeit</li>
        </ul>

        <!-- Mini reviews badge -->
        <div class="contact__badge">
          <span class="contact__stars">★★★★★</span>
          <span>5.0 auf Google</span>
        </div>

        <Terminal />
      </div>

      <!-- Right: Mini-Funnel -->
      <div class="contact__form-wrap reveal">
        <!-- Progress Bar -->
        <div class="funnel__progress">
          <div class="funnel__progress-bar" id="funnelBar" style="width: 33%"></div>
        </div>
        <div class="funnel__step-label">
          <span class="funnel__step-mono">Schritt <span id="funnelCurrent">1</span> von 3</span>
        </div>

        <!-- Step 1: Service -->
        <div class="funnel__step funnel__step--active" data-step="1">
          <h3 class="funnel__question">Wobei können wir helfen?</h3>
          <div class="funnel__cards funnel__cards--grid">
            <button type="button" class="funnel__card" data-value="google-ads">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
              <span>Google Ads</span>
            </button>
            <button type="button" class="funnel__card" data-value="social-ads">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
              <span>Social Ads</span>
            </button>
            <button type="button" class="funnel__card" data-value="webdesign">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <line x1="3" y1="9" x2="21" y2="9"/>
                <line x1="9" y1="21" x2="9" y2="9"/>
              </svg>
              <span>Webdesign</span>
            </button>
            <button type="button" class="funnel__card" data-value="tracking">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="6"/>
                <circle cx="12" cy="12" r="2"/>
              </svg>
              <span>Tracking</span>
            </button>
            <button type="button" class="funnel__card" data-value="komplett">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
              <span>Komplett-Paket</span>
            </button>
            <button type="button" class="funnel__card" data-value="beratung">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
              <span>Beratung</span>
            </button>
          </div>
        </div>

        <!-- Step 2: Budget -->
        <div class="funnel__step" data-step="2">
          <h3 class="funnel__question">Wie hoch ist dein monatliches Werbebudget?</h3>
          <div class="funnel__cards funnel__cards--list">
            <button type="button" class="funnel__option" data-value="unter-3k">
              <span class="funnel__option-label">Unter &euro;3.000/Monat</span>
              <span class="funnel__option-sub">Erste Kampagnen</span>
            </button>
            <button type="button" class="funnel__option" data-value="3k-10k">
              <span class="funnel__option-label">&euro;3.000 &ndash; &euro;10.000/Monat</span>
              <span class="funnel__option-sub">Wachstumsphase</span>
            </button>
            <button type="button" class="funnel__option" data-value="10k-30k">
              <span class="funnel__option-label">&euro;10.000 &ndash; &euro;30.000/Monat</span>
              <span class="funnel__option-sub">Skalierung</span>
            </button>
            <button type="button" class="funnel__option" data-value="ueber-30k">
              <span class="funnel__option-label">&Uuml;ber &euro;30.000/Monat</span>
              <span class="funnel__option-sub">Enterprise</span>
            </button>
            <button type="button" class="funnel__option" data-value="unklar">
              <span class="funnel__option-label">Noch unklar</span>
              <span class="funnel__option-sub">Kl&auml;ren wir im Gespr&auml;ch</span>
            </button>
          </div>
          <button type="button" class="funnel__back" data-goto="1">← Zurück</button>
        </div>

        <!-- Step 3: Contact Form -->
        <div class="funnel__step" data-step="3">
          <h3 class="funnel__question">Fast geschafft — wie erreichen wir dich?</h3>
          <form name="kontakt" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="funnel__form" id="funnelForm">
            <input type="hidden" name="form-name" value="kontakt" />
            <input type="hidden" name="interesse" id="hiddenInteresse" value="" />
            <input type="hidden" name="budget" id="hiddenBudget" value="" />
            <p class="hidden" aria-hidden="true">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <div class="funnel__field">
              <label for="f-name">Name *</label>
              <input type="text" id="f-name" name="name" required placeholder="Dein Name" />
            </div>
            <div class="funnel__field">
              <label for="f-email">Email *</label>
              <input type="email" id="f-email" name="email" required placeholder="deine@email.at" />
            </div>
            <div class="funnel__field">
              <label for="f-unternehmen">Unternehmen</label>
              <input type="text" id="f-unternehmen" name="unternehmen" placeholder="Optional" />
            </div>
            <div class="funnel__field">
              <label for="f-nachricht">Nachricht</label>
              <textarea id="f-nachricht" name="nachricht" rows="2" placeholder="Erzähl uns kurz von deinem Projekt..."></textarea>
            </div>

            <button type="submit" class="funnel__submit" data-magnetic>Kostenloses Audit anfragen</button>
            <p class="funnel__submit-note">Unverbindlich · Antwort in 24h</p>
          </form>
          <button type="button" class="funnel__back" data-goto="2">← Zurück</button>
        </div>

        <!-- Success State -->
        <div class="funnel__step funnel__success" data-step="success">
          <div class="funnel__success-icon">✓</div>
          <h3 class="funnel__question">Anfrage gesendet!</h3>
          <p class="funnel__success-text">Wir melden uns innerhalb von 24h bei dir. Schau auch in deinen Spam-Ordner.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  const wrap = document.querySelector('.contact__form-wrap');
  if (!wrap) return;

  let interesse = '';
  let budget = '';

  const bar = document.getElementById('funnelBar');
  const counter = document.getElementById('funnelCurrent');
  const stepLabel = wrap.querySelector('.funnel__step-label');

  function goToStep(step) {
    wrap.querySelectorAll('.funnel__step').forEach(s => {
      s.classList.remove('funnel__step--active');
    });

    const target = wrap.querySelector(`.funnel__step[data-step="${step}"]`);
    if (target) {
      target.classList.add('funnel__step--active');
    }

    if (step === 'success') {
      bar.style.width = '100%';
      stepLabel.style.display = 'none';
    } else {
      const pct = Math.round((step / 3) * 100);
      bar.style.width = pct + '%';
      counter.textContent = step;
      stepLabel.style.display = '';
    }
  }

  // Step 1: Service Cards
  wrap.querySelectorAll('.funnel__card').forEach(card => {
    card.addEventListener('click', () => {
      interesse = card.dataset.value;
      document.getElementById('hiddenInteresse').value = interesse;
      goToStep(2);
    });
  });

  // Step 2: Budget Options
  wrap.querySelectorAll('.funnel__option').forEach(option => {
    option.addEventListener('click', () => {
      budget = option.dataset.value;
      document.getElementById('hiddenBudget').value = budget;
      goToStep(3);
    });
  });

  // Back Buttons
  wrap.querySelectorAll('.funnel__back').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetStep = parseInt(btn.dataset.goto);
      goToStep(targetStep);
    });
  });

  // Form Submit
  const form = document.getElementById('funnelForm');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('.funnel__submit');
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Wird gesendet...';

      try {
        const formData = new FormData(form);
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(formData).toString(),
        });

        if (response.ok) {
          goToStep('success');
        } else {
          goToStep('success');
        }
      } catch (err) {
        console.error('Form error:', err);
        goToStep('success');
      }

      // DataLayer push for Google Ads / GA4
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'generate_lead',
        lead_interesse: interesse,
        lead_budget: budget,
      });

      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    });
  }
})();
</script>

<style>
  /* ===== Ambient Glows ===== */
  .contact__glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    filter: blur(100px);
    animation: contactGlowDrift 25s ease-in-out infinite alternate;
  }
  .contact__glow--cyan {
    width: 450px;
    height: 450px;
    top: -15%;
    left: -10%;
    background: rgba(0, 212, 255, 0.06);
  }
  .contact__glow--purple {
    width: 350px;
    height: 350px;
    bottom: -10%;
    right: -5%;
    background: rgba(168, 85, 247, 0.04);
    animation-delay: -12s;
    animation-duration: 35s;
  }
  @keyframes contactGlowDrift {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-25px, 20px) scale(1.08); }
    100% { transform: translate(15px, -10px) scale(0.95); }
  }
  @media (max-width: 767px) {
    .contact__glow { width: 250px; height: 250px; filter: blur(80px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .contact__glow { animation: none; }
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .contact__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact__sub {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .contact__guarantees {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
  }

  .contact__guarantees li {
    padding: 0.5rem 0;
    color: var(--text-primary);
    font-size: 0.9375rem;
  }

  .contact__guarantees li .check {
    color: var(--accent-cyan);
  }

  .contact__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    padding: 0.3rem 0.75rem;
    background: rgba(255,255,255,0.03);
    border-radius: 100px;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .contact__stars {
    color: var(--accent-yellow);
  }

  /* ===== FUNNEL WRAPPER ===== */
  .contact__form-wrap {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
  }
  .contact__form-wrap:hover {
    border-color: rgba(0,212,255,0.25);
    box-shadow: 0 0 25px rgba(0,212,255,0.12), 0 0 60px rgba(0,212,255,0.05);
  }

  /* ===== PROGRESS BAR ===== */
  .funnel__progress {
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 3px;
    margin-bottom: 1rem;
    overflow: hidden;
  }
  .funnel__progress-bar {
    height: 100%;
    background: var(--accent-cyan);
    border-radius: 3px;
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 0 8px rgba(0,212,255,0.4);
  }

  /* ===== STEP LABEL ===== */
  .funnel__step-label {
    margin-bottom: 1.25rem;
  }
  .funnel__step-mono {
    font: 500 0.7rem/1 var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  /* ===== STEPS ===== */
  .funnel__step {
    display: none;
  }
  .funnel__step--active {
    display: block;
    animation: funnelFadeIn 0.35s ease;
  }
  @keyframes funnelFadeIn {
    from { opacity: 0; transform: translateX(12px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* ===== QUESTION TITLE ===== */
  .funnel__question {
    font: 700 1.125rem/1.3 var(--font-body);
    color: var(--text-primary);
    margin-bottom: 1.25rem;
  }

  /* ===== STEP 1: SERVICE CARDS (3x2 Grid) ===== */
  .funnel__cards--grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  @media (max-width: 768px) {
    .funnel__cards--grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .funnel__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.25rem 0.75rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .funnel__card:hover {
    border-color: var(--accent-cyan);
    background: rgba(0,212,255,0.04);
    transform: translateY(-2px);
    box-shadow: 0 0 15px rgba(0,212,255,0.12);
  }
  .funnel__card:active {
    transform: translateY(0);
  }
  .funnel__card svg {
    color: var(--text-muted);
    transition: color 0.2s ease;
  }
  .funnel__card:hover svg {
    color: var(--accent-cyan);
  }

  /* ===== STEP 2: BUDGET OPTIONS (Stacked List) ===== */
  .funnel__cards--list {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .funnel__option {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    padding: 1rem 1.25rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    text-align: left;
    transition: all 0.2s ease;
    width: 100%;
  }
  .funnel__option:hover {
    border-color: var(--accent-cyan);
    background: rgba(0,212,255,0.04);
    transform: translateX(4px);
    box-shadow: 0 0 15px rgba(0,212,255,0.12);
  }
  .funnel__option-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .funnel__option-sub {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* ===== STEP 3: FORM FIELDS ===== */
  .funnel__field {
    margin-bottom: 1rem;
  }
  .funnel__field label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 0.4rem;
  }
  .funnel__field input,
  .funnel__field textarea {
    width: 100%;
    padding: 0.65rem 0.875rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    transition: border-color var(--duration) var(--ease);
  }
  .funnel__field input:focus,
  .funnel__field textarea:focus {
    outline: none;
    border-color: var(--accent-cyan);
    box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.1);
  }
  .funnel__field textarea {
    resize: vertical;
    min-height: 60px;
  }

  /* ===== SUBMIT ===== */
  .funnel__submit {
    width: 100%;
    padding: 0.875rem;
    background: var(--accent-cyan);
    color: var(--bg-primary);
    font-weight: 700;
    font-size: 1rem;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition: all var(--duration) var(--ease);
    margin-top: 0.25rem;
  }
  .funnel__submit:hover {
    filter: brightness(1.15);
    box-shadow: 0 0 25px rgba(0,212,255,0.3);
  }
  .funnel__submit-note {
    text-align: center;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.6rem;
  }

  /* ===== BACK BUTTON ===== */
  .funnel__back {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 1rem;
    padding: 0;
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .funnel__back:hover {
    color: var(--accent-cyan);
  }

  /* ===== SUCCESS STATE ===== */
  .funnel__success {
    text-align: center;
    padding: 2rem 0;
  }
  .funnel__success-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(0,212,255,0.1);
    border: 2px solid var(--accent-cyan);
    color: var(--accent-cyan);
    font-size: 1.5rem;
    font-weight: 700;
    box-shadow: 0 0 20px rgba(0,212,255,0.2);
  }
  .funnel__success-text {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.5;
  }
</style>
