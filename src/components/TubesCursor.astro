---
/**
 * TubesCursor.astro
 * Fullscreen WebGL2 glowing neon tube trail effect following the mouse cursor.
 * Renders as a fixed background layer (z-index: 0) behind page content.
 *
 * Mobile-first:
 *  - Respects prefers-reduced-motion (skips entirely)
 *  - Touch devices: fewer tubes, shorter trails, capped DPR, single bloom pass
 *  - pointer-events: none so taps/clicks always pass through to content
 *  - cursor: none only on hover-capable devices
 *  - touchmove never calls preventDefault — scrolling is never blocked
 *
 * Usage:
 *   <TubesCursor />
 *   <main class="relative z-10">...</main>
 */
---

<canvas id="tubes-cursor-canvas"></canvas>

<style>
  canvas {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    display: block;
    pointer-events: none;
  }

  @media (hover: hover) and (pointer: fine) {
    canvas {
      cursor: none;
    }
  }
</style>

<script>
  // Bail immediately if user prefers reduced motion
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const c = document.getElementById('tubes-cursor-canvas');
    if (c) c.style.display = 'none';
  } else {
    const canvas = document.getElementById('tubes-cursor-canvas') as HTMLCanvasElement;
    if (!canvas) throw new Error('TubesCursor: canvas not found');

    const gl = canvas.getContext('webgl2', { antialias: false, alpha: false });
    if (!gl) {
      canvas.style.display = 'none';
      console.warn('TubesCursor: WebGL2 not supported');
    } else {
      gl.getExtension('EXT_color_buffer_float');

      // Mobile detection: touch-primary device without hover
      const isMobile = window.matchMedia('(hover: none) and (pointer: coarse)').matches;

      // Scale down on mobile for performance
      const NUM_TUBES = isMobile ? 4 : 7;
      const TRAIL_LEN = isMobile ? 25 : 40;
      const MAX_DPR = isMobile ? 1.5 : 2;
      const BLOOM_PASSES = isMobile ? 1 : 2;

      const TUBE_COLORS = [
        { a: [1.0, 0.1, 0.5], b: [1.0, 0.7, 0.0] },
        { a: [0.1, 1.0, 0.4], b: [0.0, 0.6, 1.0] },
        { a: [1.0, 0.3, 0.0], b: [1.0, 0.0, 0.6] },
        { a: [0.5, 0.1, 1.0], b: [1.0, 0.2, 0.5] },
        { a: [0.0, 0.9, 0.9], b: [0.2, 1.0, 0.3] },
        { a: [1.0, 0.85, 0.0], b: [0.1, 1.0, 0.4] },
        { a: [1.0, 0.0, 0.6], b: [0.6, 0.1, 1.0] },
      ];

      function resize() {
        const dpr = Math.min(window.devicePixelRatio, MAX_DPR);
        canvas.width = window.innerWidth * dpr;
        canvas.height = window.innerHeight * dpr;
        canvas.style.width = window.innerWidth + 'px';
        canvas.style.height = window.innerHeight + 'px';
      }
      resize();

      let mx = 0,
        my = 0,
        mActive = false,
        tx = 0,
        ty = 0;

      // Mouse tracking (desktop)
      window.addEventListener('mousemove', (e) => {
        mx = (e.clientX / window.innerWidth) * 2 - 1;
        my = -((e.clientY / window.innerHeight) * 2 - 1);
        mActive = true;
      });
      window.addEventListener('mouseleave', () => (mActive = false));
      window.addEventListener('mouseenter', () => (mActive = true));

      // Touch tracking — passive, never blocks scrolling
      window.addEventListener(
        'touchmove',
        (e) => {
          const t = e.touches[0];
          mx = (t.clientX / window.innerWidth) * 2 - 1;
          my = -((t.clientY / window.innerHeight) * 2 - 1);
          mActive = true;
        },
        { passive: true }
      );
      window.addEventListener('touchend', () => (mActive = false));

      /* ── Shader helpers ── */
      function mkS(type: number, src: string) {
        const s = gl!.createShader(type)!;
        gl!.shaderSource(s, src);
        gl!.compileShader(s);
        if (!gl!.getShaderParameter(s, gl!.COMPILE_STATUS))
          console.error(gl!.getShaderInfoLog(s));
        return s;
      }
      function mkP(v: string, f: string) {
        const p = gl!.createProgram()!;
        gl!.attachShader(p, mkS(gl!.VERTEX_SHADER, v));
        gl!.attachShader(p, mkS(gl!.FRAGMENT_SHADER, f));
        gl!.linkProgram(p);
        if (!gl!.getProgramParameter(p, gl!.LINK_STATUS))
          console.error(gl!.getProgramInfoLog(p));
        return p;
      }

      /* ── Tube shaders ── */
      const tubeVS = `#version 300 es
precision highp float;
in vec2 aPos, aNext;
in float aSide, aAlpha;
in vec3 aCol;
uniform vec2 uRes;
uniform float uThick;
out float vAlpha, vEdge;
out vec3 vCol;
void main() {
  float ar = uRes.x / uRes.y;
  vec2 p = aPos * vec2(ar, 1.0);
  vec2 n = aNext * vec2(ar, 1.0);
  vec2 d = n - p;
  if (dot(d,d) < 1e-8) d = vec2(1.0, 0.0);
  d = normalize(d);
  vec2 nm = vec2(-d.y, d.x);
  float taper = 0.05 + aAlpha * 0.95;
  vec2 off = nm * uThick * aSide * taper;
  vec2 fp = (p + off) / vec2(ar, 1.0);
  vAlpha = aAlpha;
  vEdge = aSide;
  vCol = aCol;
  gl_Position = vec4(fp, 0.0, 1.0);
}`;

      const tubeFS = `#version 300 es
precision highp float;
in float vAlpha, vEdge;
in vec3 vCol;
out vec4 fc;
void main() {
  float e = 1.0 - abs(vEdge);
  float soft = smoothstep(0.0, 0.3, e);
  float core = pow(e, 4.0);
  vec3 c = vCol * (0.6 + core * 1.8);
  float a = vAlpha * vAlpha * vAlpha * soft;
  c *= 1.2;
  fc = vec4(c * a, a);
}`;

      const tP = mkP(tubeVS, tubeFS);
      const tL = {
        aPos: gl.getAttribLocation(tP, 'aPos'),
        aNext: gl.getAttribLocation(tP, 'aNext'),
        aSide: gl.getAttribLocation(tP, 'aSide'),
        aAlpha: gl.getAttribLocation(tP, 'aAlpha'),
        aCol: gl.getAttribLocation(tP, 'aCol'),
        uRes: gl.getUniformLocation(tP, 'uRes'),
        uThick: gl.getUniformLocation(tP, 'uThick'),
      };

      /* ── Fullscreen quad shader ── */
      const qVS = `#version 300 es
in vec2 aP;
out vec2 vUv;
void main() { vUv = aP * 0.5 + 0.5; gl_Position = vec4(aP, 0.0, 1.0); }`;

      /* ── Blur shader ── */
      const blurFS = `#version 300 es
precision highp float;
in vec2 vUv;
uniform sampler2D uTex;
uniform vec2 uDir, uRes;
out vec4 fc;
void main() {
  vec2 ts = 1.0 / uRes;
  vec4 r = vec4(0.0);
  float w[5] = float[](0.227027, 0.1945946, 0.1216216, 0.054054, 0.016216);
  r += texture(uTex, vUv) * w[0];
  for (int i = 1; i < 5; i++) {
    vec2 o = uDir * float(i) * ts;
    r += texture(uTex, vUv + o) * w[i];
    r += texture(uTex, vUv - o) * w[i];
  }
  fc = r;
}`;

      /* ── Composite shader (ACES tonemapping + vignette) ── */
      const compFS = `#version 300 es
precision highp float;
in vec2 vUv;
uniform sampler2D uScene, uBloom1, uBloom2;
out vec4 fc;
void main() {
  vec3 s = texture(uScene, vUv).rgb;
  vec3 b1 = texture(uBloom1, vUv).rgb;
  vec3 b2 = texture(uBloom2, vUv).rgb;
  vec3 c = s * 0.85 + b1 * 0.5 + b2 * 0.25;
  float lum = dot(c, vec3(0.299, 0.587, 0.114));
  if (lum > 1.0) c *= 1.0 / lum;
  c = (c * (2.51 * c + 0.03)) / (c * (2.43 * c + 0.59) + 0.14);
  vec2 uv = vUv - 0.5;
  float vig = 1.0 - dot(uv, uv) * 2.0;
  c *= smoothstep(0.0, 1.0, vig);
  c = pow(c, vec3(1.0/2.2));
  fc = vec4(c, 1.0);
}`;

      const blP = mkP(qVS, blurFS);
      const bL = {
        uTex: gl.getUniformLocation(blP, 'uTex'),
        uDir: gl.getUniformLocation(blP, 'uDir'),
        uRes: gl.getUniformLocation(blP, 'uRes'),
        aP: gl.getAttribLocation(blP, 'aP'),
      };

      const cP = mkP(qVS, compFS);
      const cL = {
        uScene: gl.getUniformLocation(cP, 'uScene'),
        uBloom1: gl.getUniformLocation(cP, 'uBloom1'),
        uBloom2: gl.getUniformLocation(cP, 'uBloom2'),
        aP: gl.getAttribLocation(cP, 'aP'),
      };

      /* ── Fullscreen quad buffer ── */
      const qB = gl.createBuffer();
      gl.bindBuffer(gl.ARRAY_BUFFER, qB);
      gl.bufferData(
        gl.ARRAY_BUFFER,
        new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]),
        gl.STATIC_DRAW
      );

      function dQ(loc: number) {
        gl!.bindBuffer(gl!.ARRAY_BUFFER, qB);
        gl!.enableVertexAttribArray(loc);
        gl!.vertexAttribPointer(loc, 2, gl!.FLOAT, false, 0, 0);
        gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
      }

      /* ── FBO helper ── */
      interface FBO {
        f: WebGLFramebuffer;
        t: WebGLTexture;
        w: number;
        h: number;
      }

      function mkFBO(w: number, h: number): FBO {
        const t = gl!.createTexture()!;
        gl!.bindTexture(gl!.TEXTURE_2D, t);
        gl!.texImage2D(gl!.TEXTURE_2D, 0, gl!.RGBA16F, w, h, 0, gl!.RGBA, gl!.FLOAT, null);
        gl!.texParameteri(gl!.TEXTURE_2D, gl!.TEXTURE_MIN_FILTER, gl!.LINEAR);
        gl!.texParameteri(gl!.TEXTURE_2D, gl!.TEXTURE_MAG_FILTER, gl!.LINEAR);
        gl!.texParameteri(gl!.TEXTURE_2D, gl!.TEXTURE_WRAP_S, gl!.CLAMP_TO_EDGE);
        gl!.texParameteri(gl!.TEXTURE_2D, gl!.TEXTURE_WRAP_T, gl!.CLAMP_TO_EDGE);
        const f = gl!.createFramebuffer()!;
        gl!.bindFramebuffer(gl!.FRAMEBUFFER, f);
        gl!.framebufferTexture2D(gl!.FRAMEBUFFER, gl!.COLOR_ATTACHMENT0, gl!.TEXTURE_2D, t, 0);
        gl!.bindFramebuffer(gl!.FRAMEBUFFER, null);
        return { f, t, w, h };
      }

      let fS: FBO, fB1a: FBO, fB1b: FBO, fB2a: FBO, fB2b: FBO;
      function buildFBOs() {
        const w = canvas.width,
          h = canvas.height;
        fS = mkFBO(w, h);
        fB1a = mkFBO((w / 2) | 0, (h / 2) | 0);
        fB1b = mkFBO((w / 2) | 0, (h / 2) | 0);
        // Quarter-res bloom FBOs only needed on desktop
        if (!isMobile) {
          fB2a = mkFBO((w / 4) | 0, (h / 4) | 0);
          fB2b = mkFBO((w / 4) | 0, (h / 4) | 0);
        }
      }
      buildFBOs();
      window.addEventListener('resize', () => {
        resize();
        buildFBOs();
      });

      /* ── Trail class ── */
      class Trail {
        colA: number[];
        colB: number[];
        pts: { x: number; y: number }[];
        phase: number;
        speed: number;
        nPh: number;
        spread: number;
        lerp: number;
        vd: Float32Array;
        vbo: WebGLBuffer;

        constructor(i: number) {
          this.colA = TUBE_COLORS[i % TUBE_COLORS.length].a;
          this.colB = TUBE_COLORS[i % TUBE_COLORS.length].b;
          this.pts = [];
          for (let j = 0; j < TRAIL_LEN; j++) this.pts.push({ x: 0, y: 0 });
          this.phase = (i / NUM_TUBES) * Math.PI * 2;
          this.speed = 0.85 + Math.random() * 0.3;
          this.nPh = Math.random() * 100;
          this.spread = 0.01 + (i / NUM_TUBES) * 0.035;
          this.lerp = 0.09 + Math.random() * 0.04;
          this.vd = new Float32Array(TRAIL_LEN * 2 * 9);
          this.vbo = gl!.createBuffer()!;
        }

        update(tx: number, ty: number, t: number) {
          const nx = Math.sin(t * 1.9 + this.nPh) * 0.01;
          const ny = Math.cos(t * 2.3 + this.nPh + 3.0) * 0.01;
          const sx = Math.sin(this.phase + t * 0.25) * this.spread;
          const sy = Math.cos(this.phase + t * 0.25) * this.spread;
          const lf = this.lerp * this.speed;
          this.pts[0].x += (tx + sx + nx - this.pts[0].x) * lf * 2.5;
          this.pts[0].y += (ty + sy + ny - this.pts[0].y) * lf * 2.5;
          for (let i = 1; i < TRAIL_LEN; i++) {
            const f = lf * (1.0 - (i / TRAIL_LEN) * 0.55);
            const snx =
              Math.sin(t * 1.1 + i * 0.07 + this.nPh) * 0.0006 * Math.sqrt(i);
            const sny =
              Math.cos(t * 1.4 + i * 0.08 + this.nPh) * 0.0006 * Math.sqrt(i);
            this.pts[i].x += (this.pts[i - 1].x - this.pts[i].x + snx) * f;
            this.pts[i].y += (this.pts[i - 1].y - this.pts[i].y + sny) * f;
          }
          const d = this.vd;
          const cA = this.colA,
            cB = this.colB;
          for (let i = 0; i < TRAIL_LEN; i++) {
            const p = this.pts[i];
            const n = this.pts[Math.min(i + 1, TRAIL_LEN - 1)];
            const a = 1.0 - i / (TRAIL_LEN - 1);
            const ct = i / (TRAIL_LEN - 1);
            const cr = cA[0] + (cB[0] - cA[0]) * ct;
            const cg = cA[1] + (cB[1] - cA[1]) * ct;
            const cb = cA[2] + (cB[2] - cA[2]) * ct;
            const b = i * 18;
            d[b] = p.x;
            d[b + 1] = p.y;
            d[b + 2] = n.x;
            d[b + 3] = n.y;
            d[b + 4] = -1;
            d[b + 5] = a;
            d[b + 6] = cr;
            d[b + 7] = cg;
            d[b + 8] = cb;
            d[b + 9] = p.x;
            d[b + 10] = p.y;
            d[b + 11] = n.x;
            d[b + 12] = n.y;
            d[b + 13] = 1;
            d[b + 14] = a;
            d[b + 15] = cr;
            d[b + 16] = cg;
            d[b + 17] = cb;
          }
          gl!.bindBuffer(gl!.ARRAY_BUFFER, this.vbo);
          gl!.bufferData(gl!.ARRAY_BUFFER, d, gl!.DYNAMIC_DRAW);
        }

        draw() {
          gl!.bindBuffer(gl!.ARRAY_BUFFER, this.vbo);
          const S = 36;
          gl!.enableVertexAttribArray(tL.aPos);
          gl!.vertexAttribPointer(tL.aPos, 2, gl!.FLOAT, false, S, 0);
          gl!.enableVertexAttribArray(tL.aNext);
          gl!.vertexAttribPointer(tL.aNext, 2, gl!.FLOAT, false, S, 8);
          gl!.enableVertexAttribArray(tL.aSide);
          gl!.vertexAttribPointer(tL.aSide, 1, gl!.FLOAT, false, S, 16);
          gl!.enableVertexAttribArray(tL.aAlpha);
          gl!.vertexAttribPointer(tL.aAlpha, 1, gl!.FLOAT, false, S, 20);
          gl!.enableVertexAttribArray(tL.aCol);
          gl!.vertexAttribPointer(tL.aCol, 3, gl!.FLOAT, false, S, 24);
          gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, TRAIL_LEN * 2);
        }
      }

      const trails: Trail[] = [];
      for (let i = 0; i < NUM_TUBES; i++) trails.push(new Trail(i));

      /* ── Blur pass ── */
      function blurPass(src: WebGLTexture, dA: FBO, dB: FBO, passes: number) {
        gl!.useProgram(blP);
        for (let p = 0; p < passes; p++) {
          const srcTex = p === 0 ? src : dB.t;
          gl!.bindFramebuffer(gl!.FRAMEBUFFER, dA.f);
          gl!.viewport(0, 0, dA.w, dA.h);
          gl!.clear(gl!.COLOR_BUFFER_BIT);
          gl!.activeTexture(gl!.TEXTURE0);
          gl!.bindTexture(gl!.TEXTURE_2D, srcTex);
          gl!.uniform1i(bL.uTex, 0);
          gl!.uniform2f(bL.uDir, 1.0, 0.0);
          gl!.uniform2f(bL.uRes, dA.w, dA.h);
          dQ(bL.aP);
          gl!.bindFramebuffer(gl!.FRAMEBUFFER, dB.f);
          gl!.viewport(0, 0, dB.w, dB.h);
          gl!.clear(gl!.COLOR_BUFFER_BIT);
          gl!.bindTexture(gl!.TEXTURE_2D, dA.t);
          gl!.uniform2f(bL.uDir, 0.0, 1.0);
          dQ(bL.aP);
        }
      }

      /* ── Render loop ── */
      let time = 0,
        prev = performance.now();
      let rafId: number;

      function frame(now: number) {
        rafId = requestAnimationFrame(frame);
        const dt = Math.min((now - prev) / 1000, 0.05);
        prev = now;
        time += dt;

        if (mActive) {
          tx += (mx - tx) * 0.12;
          ty += (my - ty) * 0.12;
        } else {
          // Lissajous sleep pattern
          tx += (Math.sin(time * 0.5) * 0.3 - tx) * 0.025;
          ty += (Math.sin(time * 1.0) * 0.18 - ty) * 0.025;
        }

        for (const tr of trails) tr.update(tx, ty, time);

        // Pass 1: Render tubes to HDR framebuffer
        gl!.bindFramebuffer(gl!.FRAMEBUFFER, fS.f);
        gl!.viewport(0, 0, fS.w, fS.h);
        gl!.clearColor(0, 0, 0, 1);
        gl!.clear(gl!.COLOR_BUFFER_BIT);
        gl!.enable(gl!.BLEND);
        gl!.blendFunc(gl!.SRC_ALPHA, gl!.ONE);
        gl!.useProgram(tP);
        gl!.uniform2f(tL.uRes, canvas.width, canvas.height);
        gl!.uniform1f(tL.uThick, 0.005);
        for (const tr of trails) tr.draw();
        gl!.disable(gl!.BLEND);

        // Pass 2: Gaussian bloom — single level on mobile, two levels on desktop
        blurPass(fS.t, fB1a, fB1b, BLOOM_PASSES);
        if (!isMobile) {
          blurPass(fS.t, fB2a, fB2b, BLOOM_PASSES);
        }

        // Pass 3: Composite with tonemapping + vignette
        gl!.bindFramebuffer(gl!.FRAMEBUFFER, null);
        gl!.viewport(0, 0, canvas.width, canvas.height);
        gl!.clearColor(0, 0, 0, 1);
        gl!.clear(gl!.COLOR_BUFFER_BIT);
        gl!.useProgram(cP);
        gl!.activeTexture(gl!.TEXTURE0);
        gl!.bindTexture(gl!.TEXTURE_2D, fS.t);
        gl!.uniform1i(cL.uScene, 0);
        gl!.activeTexture(gl!.TEXTURE1);
        gl!.bindTexture(gl!.TEXTURE_2D, fB1b.t);
        gl!.uniform1i(cL.uBloom1, 1);
        gl!.activeTexture(gl!.TEXTURE2);
        // On mobile, feed bloom1 into bloom2 slot (no second pass)
        gl!.bindTexture(gl!.TEXTURE_2D, isMobile ? fB1b.t : fB2b.t);
        gl!.uniform1i(cL.uBloom2, 2);
        dQ(cL.aP);
      }

      rafId = requestAnimationFrame(frame);

      // Cleanup on Astro View Transitions
      document.addEventListener('astro:before-swap', () => {
        cancelAnimationFrame(rafId);
        gl!.getExtension('WEBGL_lose_context')?.loseContext();
      });
    }
  }
</script>
