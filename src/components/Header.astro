---
/**
 * Header.astro
 * Sticky navigation: transparent → blur on scroll, scroll progress bar,
 * desktop nav with mega menu, mobile fullscreen overlay, green CTA pill.
 */
import { services } from '../data/services';
import Logo from './Logo.astro';

const colorMap: Record<string, string> = {
  green: '5, 223, 114',
  cyan: '0, 212, 255',
  pink: '255, 45, 120',
  yellow: '255, 214, 0',
  orange: '255, 140, 66',
  purple: '168, 85, 247',
  red: '242, 78, 82',
};

const slugMap: Record<string, string> = {
  'webdesign-entwicklung': 'webdesign',
};

const navLinks = [
  { label: 'Agency', href: '#about' },
  { label: 'Ablauf', href: '#ablauf' },
  { label: 'Blog', href: '/blog' },
  { label: 'Kontakt', href: '#kontakt' },
];
---

<header class="header" id="site-header">
  <nav class="nav">
    <div class="nav__inner container">
      <a href="/" class="nav__logo" aria-label="Timito Media – Startseite">
        <Logo height={28} />
      </a>

      <ul class="nav__links" role="list">
        <!-- Leistungen with mega menu -->
        <li class="nav__dropdown" id="megaDropdown">
          <button class="nav__link nav__link--trigger" id="megaTrigger" aria-expanded="false" aria-haspopup="true" type="button">
            Leistungen
            <svg class="nav__link-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </button>
        </li>
        {navLinks.map((link) => (
          <li><a href={link.href} class="nav__link">{link.label}</a></li>
        ))}
      </ul>

      <a href="#kontakt" class="nav__cta">
        Kostenloses Audit anfragen <span aria-hidden="true">&nearr;</span>
      </a>

      <button
        class="nav__burger"
        id="navBurger"
        type="button"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Mega Menu Panel -->
  <div class="mega" id="megaPanel" role="menu" aria-label="Leistungen">
    <div class="mega__inner container">
      <div class="mega__grid">
        {services.map((s) => (
          <a
            href={`/leistungen/${slugMap[s.slug] || s.slug}`}
            class="mega__item"
            role="menuitem"
            style={`--item-c: ${colorMap[s.color]}`}
          >
            <div class="mega__item-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={`rgb(${colorMap[s.color]})`} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={s.iconPath} />
              </svg>
            </div>
            <div class="mega__item-body">
              <span class="mega__item-name">{s.name}</span>
              <span class="mega__item-tagline">{s.tagline}</span>
            </div>
            <span class="mega__item-arrow" aria-hidden="true">&rarr;</span>
          </a>
        ))}
      </div>
      <div class="mega__footer">
        <a href="#leistungen" class="mega__footer-link" id="megaOverviewLink">Alle Leistungen im Überblick &darr;</a>
      </div>
    </div>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" role="dialog" aria-modal="true" aria-label="Navigation" hidden>
  <nav class="mobile-menu__nav">
    <span class="mobile-menu__label">Leistungen</span>
    <div class="mobile-menu__services">
      {services.map((s) => (
        <a href={`/leistungen/${slugMap[s.slug] || s.slug}`} class="mobile-menu__service-link" style={`--item-c: ${colorMap[s.color]}`}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={`rgb(${colorMap[s.color]})`} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d={s.iconPath} />
          </svg>
          {s.name}
        </a>
      ))}
    </div>
    <span class="mobile-menu__divider"></span>
    {navLinks.map((link) => (
      <a href={link.href} class="mobile-menu__link">{link.label}</a>
    ))}
    <a href="#kontakt" class="mobile-menu__cta nav__cta">
      Kostenloses Audit anfragen <span aria-hidden="true">&nearr;</span>
    </a>
  </nav>
</div>

<script>
  (function () {
    const header = document.getElementById('site-header');
    const burger = document.getElementById('navBurger');
    const menu = document.getElementById('mobile-menu');
    const megaTrigger = document.getElementById('megaTrigger');
    const megaPanel = document.getElementById('megaPanel');
    const megaDropdown = document.getElementById('megaDropdown');
    const megaOverviewLink = document.getElementById('megaOverviewLink');
    if (!header || !burger || !menu) return;

    // Scroll: add .is-scrolled
    function onScroll() {
      header.classList.toggle('is-scrolled', window.scrollY > 20);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // ===== Mega Menu =====
    let megaOpen = false;
    let closeTimeout: number | null = null;

    function openMega() {
      if (!megaTrigger || !megaPanel) return;
      if (closeTimeout) { clearTimeout(closeTimeout); closeTimeout = null; }
      megaOpen = true;
      megaTrigger.setAttribute('aria-expanded', 'true');
      megaPanel.classList.add('is-open');
    }

    function closeMega() {
      if (!megaTrigger || !megaPanel) return;
      megaOpen = false;
      megaTrigger.setAttribute('aria-expanded', 'false');
      megaPanel.classList.remove('is-open');
    }

    function delayedClose() {
      closeTimeout = window.setTimeout(closeMega, 200);
    }

    if (megaTrigger && megaPanel && megaDropdown) {
      // Hover
      megaDropdown.addEventListener('mouseenter', openMega);
      megaDropdown.addEventListener('mouseleave', delayedClose);
      megaPanel.addEventListener('mouseenter', () => {
        if (closeTimeout) { clearTimeout(closeTimeout); closeTimeout = null; }
      });
      megaPanel.addEventListener('mouseleave', delayedClose);

      // Click toggle
      megaTrigger.addEventListener('click', () => {
        megaOpen ? closeMega() : openMega();
      });

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && megaOpen) closeMega();
      });

      // Close when clicking outside
      document.addEventListener('click', (e) => {
        if (megaOpen && !(e.target as Element)?.closest('#megaDropdown, #megaPanel')) {
          closeMega();
        }
      });

      // Close mega on link click (anchor links)
      if (megaOverviewLink) {
        megaOverviewLink.addEventListener('click', () => closeMega());
      }
      megaPanel.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => closeMega());
      });
    }

    // ===== Mobile menu toggle =====
    function openMenu() {
      menu.hidden = false;
      requestAnimationFrame(() => menu.classList.add('is-open'));
      burger.classList.add('is-active');
      burger.setAttribute('aria-expanded', 'true');
      burger.setAttribute('aria-label', 'Menü schließen');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      menu.classList.remove('is-open');
      burger.classList.remove('is-active');
      burger.setAttribute('aria-expanded', 'false');
      burger.setAttribute('aria-label', 'Menü öffnen');
      document.body.style.overflow = '';
      setTimeout(() => { menu.hidden = true; }, 300);
    }

    burger.addEventListener('click', () => {
      menu.hidden || !menu.classList.contains('is-open') ? openMenu() : closeMenu();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) closeMenu();
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => closeMenu());
    });

  })();
</script>

<style>
  /* ===== HEADER SHELL ===== */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 90;
    padding: 0.75rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-left: 1rem;
    padding-right: 1rem;
    transition: padding var(--duration) var(--ease);
  }

  .header.is-scrolled {
    padding: 0.5rem 1rem;
  }

  /* ===== NAV — floating glass pill ===== */
  .nav {
    position: relative;
    width: 100%;
    max-width: var(--container);
    margin-inline: auto;
    padding-inline: 1.25rem;
    background: rgba(10, 10, 18, 0.45);
    backdrop-filter: blur(24px) saturate(1.3);
    -webkit-backdrop-filter: blur(24px) saturate(1.3);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 999px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2), inset 0 0 0 1px rgba(255, 255, 255, 0.03);
    transition: background var(--duration) var(--ease),
                border-color var(--duration) var(--ease),
                box-shadow var(--duration) var(--ease);
  }

  .header.is-scrolled .nav {
    background: rgba(10, 10, 18, 0.8);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(255,255,255,0.03) inset;
  }

  /* ===== NAV INNER ===== */
  .nav__inner {
    display: flex;
    align-items: center;
    height: 56px;
    padding: 0 1.5rem;
    gap: 2rem;
  }

  /* ===== LOGO ===== */
  .nav__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .nav__logo-img {
    height: 28px;
    width: auto;
    display: block;
  }

  /* ===== DESKTOP LINKS ===== */
  .nav__links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    margin-left: auto;
  }

  .nav__link {
    font: 500 0.85rem/1 var(--font-body);
    color: var(--text-secondary);
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    transition: color var(--duration) var(--ease),
                background var(--duration) var(--ease);
    text-decoration: none;
    white-space: nowrap;
  }

  .nav__link:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  /* ===== DROPDOWN TRIGGER ===== */
  .nav__dropdown {
    position: relative;
  }

  .nav__link--trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: none;
    border: none;
    cursor: pointer;
  }

  .nav__link-chevron {
    transition: transform 0.25s var(--ease);
    flex-shrink: 0;
  }

  .nav__link--trigger[aria-expanded="true"] .nav__link-chevron {
    transform: rotate(180deg);
  }

  .nav__link--trigger[aria-expanded="true"] {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  /* ===== CTA BUTTON ===== */
  .nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: 0.5rem;
    padding: 0.5rem 1.1rem;
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    background: var(--accent-cyan);
    color: var(--bg-primary);
    border-radius: 999px;
    text-decoration: none;
    box-shadow: 0 0 15px rgba(0, 212, 255, 0.15);
    transition: background var(--duration) var(--ease),
                box-shadow var(--duration) var(--ease),
                transform var(--duration) var(--ease);
  }

  .nav__cta:hover {
    background: #33ddff;
    box-shadow: 0 0 25px rgba(0, 212, 255, 0.3);
    transform: translateY(-1px);
  }

  .nav__cta:active {
    transform: translateY(0);
  }

  /* ===== MEGA MENU ===== */
  .mega {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 89;
    padding-top: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    pointer-events: none;
    transition: opacity 0.25s var(--ease),
                transform 0.25s var(--ease),
                visibility 0.25s;
  }

  .mega.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .mega__inner {
    max-width: var(--container);
    margin-inline: auto;
    padding: 1.5rem;
    background: rgba(10, 10, 18, 0.92);
    backdrop-filter: blur(32px) saturate(1.3);
    -webkit-backdrop-filter: blur(32px) saturate(1.3);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    box-shadow: 0 16px 64px rgba(0, 0, 0, 0.4),
                inset 0 0 0 1px rgba(255, 255, 255, 0.03);
  }

  .mega__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.5rem;
  }

  .mega__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s var(--ease);
  }

  .mega__item:hover {
    background: rgba(var(--item-c), 0.06);
  }

  .mega__item-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: rgba(var(--item-c), 0.08);
    border: 1px solid rgba(var(--item-c), 0.15);
  }

  .mega__item-body {
    flex: 1;
    min-width: 0;
  }

  .mega__item-name {
    display: block;
    font: 600 0.85rem/1.3 var(--font-body);
    color: var(--text-primary);
  }

  .mega__item-tagline {
    display: block;
    font: 400 0.7rem/1.4 var(--font-body);
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mega__item-arrow {
    flex-shrink: 0;
    color: rgba(var(--item-c), 0);
    font-size: 0.9rem;
    transition: color 0.2s var(--ease), transform 0.2s var(--ease);
  }

  .mega__item:hover .mega__item-arrow {
    color: rgb(var(--item-c));
    transform: translateX(3px);
  }

  .mega__footer {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    text-align: center;
  }

  .mega__footer-link {
    font: 500 0.75rem/1 var(--font-mono);
    color: var(--text-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color 0.2s var(--ease);
  }

  .mega__footer-link:hover {
    color: var(--accent-cyan);
  }

  /* ===== BURGER (Mobile) ===== */
  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-left: auto;
    z-index: 100;
  }

  .nav__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: transform 0.3s var(--ease), opacity 0.3s var(--ease);
  }

  .nav__burger.is-active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav__burger.is-active span:nth-child(2) {
    opacity: 0;
  }

  .nav__burger.is-active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ===== MOBILE MENU ===== */
  .mobile-menu {
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 15, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 89;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s var(--ease);
  }

  .mobile-menu[hidden] {
    display: none;
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 360px;
    padding: 0 1.5rem;
  }

  .mobile-menu__label {
    font: 600 0.65rem/1 var(--font-mono);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.25rem;
  }

  .mobile-menu__services {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    width: 100%;
  }

  .mobile-menu__service-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    font: 500 0.95rem/1 var(--font-body);
    color: var(--text-secondary);
    text-decoration: none;
    transition: background 0.2s var(--ease), color 0.2s var(--ease);
  }

  .mobile-menu__service-link:hover {
    background: rgba(var(--item-c), 0.08);
    color: var(--text-primary);
  }

  .mobile-menu__divider {
    width: 60%;
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin: 0.5rem 0;
  }

  .mobile-menu__link {
    font: 600 1.5rem/1 var(--font-body);
    color: var(--text-primary);
    text-decoration: none;
    padding: 0.5rem;
    transition: color var(--duration) var(--ease);
  }

  .mobile-menu__link:hover {
    color: var(--accent-cyan);
  }

  .mobile-menu__cta {
    margin-top: 1rem;
    padding: 0.75rem 1.75rem;
    font-size: 1rem;
  }

  /* Prevent scroll when menu open */
  :global(body[style*="overflow: hidden"]) {
    overflow: hidden;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1023px) {
    .nav__links,
    .nav__inner > .nav__cta {
      display: none;
    }

    .nav__burger {
      display: flex;
    }

    .mega {
      display: none;
    }
  }
</style>
