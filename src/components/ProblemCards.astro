---
import SectionLabel from './SectionLabel.astro';
import SplitWords from './SplitWords.astro';

interface Props {
  sectionTitle: string;
  cards: Array<{ title: string; text: string }>;
  resolution: { title: string; paragraphs: string[] };
  colorRGB: string;
}

const { sectionTitle, cards, resolution, colorRGB } = Astro.props;
---

<section id="problem" class="svc-problems section" style={`--svc-c: ${colorRGB}`}>
  <div class="container">
    <SectionLabel text="// Das Problem" />
    <h2 class="svc-problems__title" data-split-reveal style="overflow:hidden"><SplitWords text={sectionTitle} gap="0.28em" /></h2>
    <div class="problem-grid reveal-stagger">
      {cards.map(card => (
        <div class="problem-card">
          <h3>{card.title}</h3>
          <p>{card.text}</p>
        </div>
      ))}
    </div>
    <div class="resolution reveal">
      <h3>{resolution.title}</h3>
      {resolution.paragraphs.map(p => (
        <p set:html={p} />
      ))}
    </div>
  </div>
</section>
