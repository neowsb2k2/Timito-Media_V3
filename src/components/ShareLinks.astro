---
interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);

const linkedInHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
const xHref = `https://x.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`;
---

<div class="share-links">
  <span class="share-links__label">// Teilen</span>
  <div class="share-links__buttons">
    <a
      href={linkedInHref}
      target="_blank"
      rel="noopener noreferrer"
      class="share-links__btn"
      aria-label="Auf LinkedIn teilen"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>
    <a
      href={xHref}
      target="_blank"
      rel="noopener noreferrer"
      class="share-links__btn"
      aria-label="Auf X teilen"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>
  </div>
</div>

<style>
  .share-links__label {
    display: block;
    font: 700 0.7rem/1 var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-cyan);
    margin-bottom: 0.75rem;
  }

  .share-links__buttons {
    display: flex;
    gap: 0.5rem;
  }

  .share-links__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition:
      color var(--duration) var(--ease),
      border-color var(--duration) var(--ease),
      box-shadow var(--duration) var(--ease);
  }

  .share-links__btn:hover {
    color: var(--accent-cyan);
    border-color: rgba(0, 212, 255, 0.3);
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.1);
  }

  .share-links__btn svg {
    display: block;
  }
</style>
