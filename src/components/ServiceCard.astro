---
interface Props {
  name: string;
  slug: string;
  color: string;
  iconPath: string;
  tagline: string;
  features: string[];
  proofNum: string;
  proofLabel: string;
}

const { name, slug, color, iconPath, tagline, features, proofNum, proofLabel } = Astro.props;
---

<a href="#leistungen" class="svc-card reveal" style={`--svc-accent: var(--accent-${color})`}>
  <div class="svc-card__icon">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d={iconPath} />
    </svg>
  </div>
  <h3 class="svc-card__name">{name}</h3>
  <p class="svc-card__tagline">{tagline}</p>
  <ul class="svc-card__features">
    {features.map((f) => <li>{f}</li>)}
  </ul>
  <div class="svc-card__proof">
    <span class="svc-card__proof-num">{proofNum}</span>
    <span class="svc-card__proof-label">{proofLabel}</span>
  </div>
</a>

<style>
  .svc-card {
    display: flex;
    flex-direction: column;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-top: 2px solid var(--svc-accent);
    border-radius: var(--radius);
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    transition:
      border-color var(--duration) var(--ease),
      transform var(--duration) var(--ease),
      box-shadow var(--duration) var(--ease);
  }

  .svc-card:hover {
    border-color: var(--svc-accent);
    transform: translateY(-2px);
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.12), 0 0 50px rgba(0, 212, 255, 0.05);
  }

  .svc-card__icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--svc-accent);
    margin-bottom: 1.25rem;
  }

  .svc-card__name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .svc-card__tagline {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
    line-height: 1.5;
  }

  .svc-card__features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    flex-grow: 1;
  }

  .svc-card__features li {
    font-size: 0.8125rem;
    color: var(--text-muted);
    padding: 0.3rem 0;
    padding-left: 1rem;
    position: relative;
  }

  .svc-card__features li::before {
    content: '\2192';
    position: absolute;
    left: 0;
    color: var(--svc-accent);
    font-size: 0.75rem;
  }

  .svc-card__proof {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    margin-top: auto;
  }

  .svc-card__proof-num {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--svc-accent);
    display: block;
  }

  .svc-card__proof-label {
    font-size: 0.75rem;
    color: var(--text-muted);
  }
</style>
