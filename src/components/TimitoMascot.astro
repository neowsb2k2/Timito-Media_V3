---
/**
 * TimitoMascot.astro
 * Reusable wireframe robot mascot SVG with 6 pose variants.
 * Geometric cyan outlines, animated float/pulse/glow.
 */
interface Props {
  pose: 'idle' | 'crossed' | 'pointing' | 'waving' | 'thinking' | 'broken';
  class?: string;
}

const { pose, class: className } = Astro.props;
---

<div class:list={['timito-mascot', `pose-${pose}`, className]}>
  <svg class="timito-svg" viewBox="0 0 200 280" fill="none" xmlns="http://www.w3.org/2000/svg">

    {/* ===== IDLE ===== */}
    {pose === 'idle' && (
      <g class="timito-group">
        <ellipse cx="100" cy="62" rx="38" ry="48" stroke="rgba(0,212,255,0.18)" stroke-width="1.2" fill="rgba(0,212,255,0.02)"/>
        <path d="M72 58 Q100 52 128 58" stroke="rgba(0,212,255,0.3)" stroke-width="1.5" fill="none"/>
        <g class="eyes">
          <ellipse cx="87" cy="64" rx="7" ry="3.5" fill="rgba(0,212,255,0.35)" stroke="rgba(0,212,255,0.15)" stroke-width="0.5"/>
          <ellipse cx="113" cy="64" rx="7" ry="3.5" fill="rgba(0,212,255,0.35)" stroke="rgba(0,212,255,0.15)" stroke-width="0.5"/>
        </g>
        <rect x="91" y="108" width="18" height="14" rx="3" stroke="rgba(0,212,255,0.08)" stroke-width="1" fill="rgba(0,212,255,0.01)"/>
        <path d="M65 122 L60 210 Q60 218 100 220 Q140 218 140 210 L135 122 Z" stroke="rgba(0,212,255,0.12)" stroke-width="1.2" fill="rgba(0,212,255,0.015)"/>
        <circle cx="100" cy="165" r="14" stroke="rgba(0,212,255,0.08)" stroke-width="1" fill="none"/>
        <circle class="core-glow" cx="100" cy="165" r="8" fill="rgba(0,212,255,0.05)"/>
        <circle class="core-dot" cx="100" cy="165" r="4" fill="rgba(0,212,255,0.35)"/>
        <line x1="65" y1="130" x2="38" y2="195" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
        <line x1="135" y1="130" x2="162" y2="195" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
        <line x1="85" y1="218" x2="78" y2="268" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
        <line x1="115" y1="218" x2="122" y2="268" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
      </g>
    )}

    {/* ===== CROSSED ===== */}
    {pose === 'crossed' && (
      <>
        <g class="timito-group">
          <ellipse cx="100" cy="62" rx="38" ry="48" stroke="rgba(0,212,255,0.18)" stroke-width="1.2" fill="rgba(0,212,255,0.02)"/>
          <path d="M72 58 Q100 52 128 58" stroke="rgba(0,212,255,0.3)" stroke-width="1.5" fill="none"/>
          <g class="eyes">
            <ellipse cx="87" cy="64" rx="7" ry="3.5" fill="rgba(0,212,255,0.35)"/>
            <ellipse cx="113" cy="64" rx="7" ry="3.5" fill="rgba(0,212,255,0.35)"/>
          </g>
          <rect x="91" y="108" width="18" height="14" rx="3" stroke="rgba(0,212,255,0.08)" fill="rgba(0,212,255,0.01)"/>
          <path d="M65 122 L60 210 Q60 218 100 220 Q140 218 140 210 L135 122 Z" stroke="rgba(0,212,255,0.12)" stroke-width="1.2" fill="rgba(0,212,255,0.015)"/>
          <circle cx="100" cy="165" r="14" stroke="rgba(0,212,255,0.1)" fill="none"/>
          <circle class="core-dot" cx="100" cy="165" r="4" fill="rgba(0,212,255,0.35)"/>
          <line x1="65" y1="135" x2="120" y2="160" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
          <line x1="135" y1="135" x2="80" y2="160" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
        </g>
        <path d="M0 210 Q25 205 50 210 Q75 215 100 210 Q125 205 150 210 Q175 215 200 210 L200 280 L0 280Z" fill="rgba(0,212,255,0.02)" stroke="rgba(0,212,255,0.08)" stroke-width="0.5"/>
        <path d="M0 220 Q30 225 60 220 Q90 215 120 220 Q150 225 180 220 Q200 217 200 220 L200 280 L0 280Z" fill="rgba(0,0,0,0.5)"/>
        <path d="M0 235 Q50 238 100 235 Q150 232 200 235 L200 280 L0 280Z" fill="var(--bg-primary, #0a0a0f)"/>
      </>
    )}

    {/* ===== POINTING ===== */}
    {pose === 'pointing' && (
      <g class="timito-group">
        <g class="head">
          <ellipse cx="100" cy="62" rx="38" ry="48" stroke="rgba(0,212,255,0.18)" stroke-width="1.2" fill="rgba(0,212,255,0.02)"/>
          <path d="M72 58 Q100 52 128 58" stroke="rgba(0,212,255,0.3)" stroke-width="1.5" fill="none"/>
          <g class="eyes">
            <ellipse cx="87" cy="64" rx="7" ry="3.5" fill="rgba(0,212,255,0.35)"/>
            <ellipse cx="113" cy="64" rx="7" ry="3.5" fill="rgba(0,212,255,0.35)"/>
          </g>
        </g>
        <g class="scan-beam" opacity="0.5">
          <line x1="120" y1="64" x2="185" y2="64" stroke="rgba(0,212,255,0.3)" stroke-width="0.5" stroke-dasharray="2 3"/>
          <circle cx="185" cy="64" r="2" fill="rgba(0,212,255,0.3)"/>
        </g>
        <rect x="91" y="108" width="18" height="14" rx="3" stroke="rgba(0,212,255,0.08)" fill="rgba(0,212,255,0.01)"/>
        <path d="M65 122 L60 210 Q60 218 100 220 Q140 218 140 210 L135 122 Z" stroke="rgba(0,212,255,0.12)" stroke-width="1.2" fill="rgba(0,212,255,0.015)"/>
        <circle cx="100" cy="165" r="14" stroke="rgba(0,212,255,0.1)" fill="none"/>
        <circle class="core-dot" cx="100" cy="165" r="4" fill="rgba(0,212,255,0.35)"/>
        <line x1="65" y1="130" x2="38" y2="195" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
        <line x1="135" y1="130" x2="170" y2="110" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
        <rect x="158" y="80" width="35" height="45" rx="2" stroke="rgba(0,212,255,0.12)" fill="rgba(0,212,255,0.02)"/>
        <line x1="163" y1="90" x2="183" y2="90" stroke="rgba(0,212,255,0.12)" stroke-width="0.8"/>
        <line x1="163" y1="97" x2="178" y2="97" stroke="rgba(0,212,255,0.08)" stroke-width="0.8"/>
        <line x1="163" y1="104" x2="188" y2="104" stroke="rgba(0,212,255,0.06)" stroke-width="0.8"/>
        <rect x="163" y="110" width="8" height="8" fill="rgba(0,212,255,0.06)"/>
        <rect x="174" y="110" width="6" height="8" fill="rgba(5,223,114,0.06)"/>
        <line x1="85" y1="218" x2="78" y2="268" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
        <line x1="115" y1="218" x2="122" y2="268" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
      </g>
    )}

    {/* ===== WAVING ===== */}
    {pose === 'waving' && (
      <g class="timito-group">
        <ellipse cx="100" cy="62" rx="38" ry="48" stroke="rgba(0,212,255,0.18)" stroke-width="1.2" fill="rgba(0,212,255,0.02)"/>
        <path d="M72 58 Q100 52 128 58" stroke="rgba(0,212,255,0.3)" stroke-width="1.5" fill="none"/>
        <g class="eyes">
          <path d="M80 66 Q87 58 94 66" stroke="rgba(0,212,255,0.6)" stroke-width="2" fill="none" stroke-linecap="round"/>
          <path d="M106 66 Q113 58 120 66" stroke="rgba(0,212,255,0.6)" stroke-width="2" fill="none" stroke-linecap="round"/>
        </g>
        <line x1="100" y1="14" x2="100" y2="3" stroke="rgba(0,212,255,0.3)" stroke-width="1"/>
        <circle class="antenna-tip" cx="100" cy="2" r="2.5" fill="rgba(0,212,255,0.35)"/>
        <rect x="91" y="108" width="18" height="14" rx="3" stroke="rgba(0,212,255,0.08)" fill="rgba(0,212,255,0.01)"/>
        <path d="M65 122 L60 210 Q60 218 100 220 Q140 218 140 210 L135 122 Z" stroke="rgba(0,212,255,0.12)" stroke-width="1.2" fill="rgba(0,212,255,0.015)"/>
        <circle cx="100" cy="165" r="14" stroke="rgba(0,212,255,0.1)" fill="none"/>
        <circle class="core-dot" cx="100" cy="165" r="4" fill="rgba(0,212,255,0.35)"/>
        <line x1="65" y1="130" x2="42" y2="190" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
        <g class="arm-right">
          <line x1="135" y1="130" x2="165" y2="85" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
          <circle cx="165" cy="82" r="5" stroke="rgba(0,212,255,0.2)" fill="rgba(0,212,255,0.03)"/>
        </g>
        <line x1="85" y1="218" x2="78" y2="268" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
        <line x1="115" y1="218" x2="122" y2="268" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
      </g>
    )}

    {/* ===== THINKING ===== */}
    {pose === 'thinking' && (
      <g class="timito-group">
        <ellipse cx="100" cy="62" rx="38" ry="48" stroke="rgba(0,212,255,0.18)" stroke-width="1.2" fill="rgba(0,212,255,0.02)"/>
        <path d="M72 58 Q100 52 128 58" stroke="rgba(0,212,255,0.3)" stroke-width="1.5" fill="none"/>
        <g class="eyes">
          <ellipse cx="87" cy="64" rx="7" ry="3.5" fill="rgba(0,212,255,0.3)" stroke="rgba(0,212,255,0.3)" stroke-width="0.5"/>
          <ellipse cx="113" cy="64" rx="7" ry="3.5" fill="rgba(0,212,255,0.3)" stroke="rgba(0,212,255,0.3)" stroke-width="0.5"/>
          <g class="pupils">
            <circle cx="88" cy="64" r="2" fill="rgba(0,212,255,0.8)"/>
            <circle cx="114" cy="64" r="2" fill="rgba(0,212,255,0.8)"/>
          </g>
        </g>
        <rect x="91" y="108" width="18" height="14" rx="3" stroke="rgba(0,212,255,0.08)" fill="rgba(0,212,255,0.01)"/>
        <path d="M65 122 L60 210 Q60 218 100 220 Q140 218 140 210 L135 122 Z" stroke="rgba(0,212,255,0.12)" stroke-width="1.2" fill="rgba(0,212,255,0.015)"/>
        <circle cx="100" cy="165" r="14" stroke="rgba(0,212,255,0.1)" fill="none"/>
        <circle class="core-dot" cx="100" cy="165" r="4" fill="rgba(0,212,255,0.35)"/>
        <polyline points="65,130 48,160 55,168 72,85" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <line x1="135" y1="130" x2="155" y2="195" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
        <polyline points="15,240 35,228 55,235 75,218 95,225 115,210" stroke="rgba(0,212,255,0.1)" stroke-width="1" fill="none"/>
        <polyline points="15,250 35,245 55,248 75,238 95,242 115,232" stroke="rgba(5,223,114,0.08)" stroke-width="0.8" fill="none"/>
        <line x1="85" y1="218" x2="78" y2="268" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
        <line x1="115" y1="218" x2="122" y2="268" stroke="rgba(0,212,255,0.12)" stroke-width="6" stroke-linecap="round"/>
      </g>
    )}

    {/* ===== BROKEN ===== */}
    {pose === 'broken' && (
      <g class="timito-group">
        <ellipse cx="100" cy="62" rx="38" ry="48" stroke="rgba(255,45,120,0.08)" stroke-width="1.2" fill="rgba(255,45,120,0.01)"/>
        <path d="M72 58 Q100 52 128 58" stroke="rgba(255,45,120,0.18)" stroke-width="1.5" fill="none"/>
        <g class="eyes">
          <line x1="81" y1="59" x2="93" y2="69" stroke="rgba(255,45,120,0.5)" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="93" y1="59" x2="81" y2="69" stroke="rgba(255,45,120,0.5)" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="107" y1="59" x2="119" y2="69" stroke="rgba(255,45,120,0.5)" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="119" y1="59" x2="107" y2="69" stroke="rgba(255,45,120,0.5)" stroke-width="1.5" stroke-linecap="round"/>
        </g>
        <line x1="100" y1="14" x2="100" y2="5" stroke="rgba(255,45,120,0.15)" stroke-width="1"/>
        <line x1="100" y1="5" x2="106" y2="1" stroke="rgba(255,45,120,0.15)" stroke-width="1"/>
        <circle cx="106" cy="0" r="2" fill="rgba(255,45,120,0.2)"/>
        <rect x="91" y="108" width="18" height="14" rx="3" stroke="rgba(255,45,120,0.1)" fill="rgba(255,45,120,0.01)"/>
        <path d="M65 122 L60 210 Q60 218 100 220 Q140 218 140 210 L135 122 Z" stroke="rgba(255,45,120,0.08)" stroke-width="1.2" fill="rgba(255,45,120,0.01)"/>
        <circle cx="100" cy="165" r="14" stroke="rgba(255,45,120,0.07)" fill="none"/>
        <circle class="core-dot" cx="100" cy="165" r="4" fill="rgba(255,45,120,0.4)"/>
        <line x1="65" y1="130" x2="45" y2="210" stroke="rgba(255,45,120,0.1)" stroke-width="6" stroke-linecap="round"/>
        <line x1="135" y1="130" x2="155" y2="210" stroke="rgba(255,45,120,0.1)" stroke-width="6" stroke-linecap="round"/>
        <g class="spark1"><line x1="48" y1="90" x2="40" y2="83" stroke="rgba(255,45,120,0.5)" stroke-width="1.5" stroke-linecap="round"/></g>
        <g class="spark2"><line x1="152" y1="100" x2="160" y2="93" stroke="rgba(255,45,120,0.4)" stroke-width="1.5" stroke-linecap="round"/></g>
        <g class="spark3"><line x1="55" y1="185" x2="47" y2="180" stroke="rgba(255,45,120,0.3)" stroke-width="1" stroke-linecap="round"/></g>
        <line x1="85" y1="218" x2="78" y2="268" stroke="rgba(255,45,120,0.1)" stroke-width="6" stroke-linecap="round"/>
        <line x1="115" y1="218" x2="122" y2="268" stroke="rgba(255,45,120,0.1)" stroke-width="6" stroke-linecap="round"/>
      </g>
    )}

  </svg>
</div>

<style>
  /* ===== WRAPPER ===== */
  .timito-mascot {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .timito-svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 0 15px rgba(0,212,255,0.12))
            drop-shadow(0 0 40px rgba(0,212,255,0.06));
  }

  .pose-broken .timito-svg {
    filter: drop-shadow(0 0 15px rgba(255,45,120,0.1))
            drop-shadow(0 0 40px rgba(255,45,120,0.05));
  }

  /* ===== KEYFRAMES ===== */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  @keyframes eyePulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }
  @keyframes corePulse {
    0%, 100% { opacity: 0.3; filter: drop-shadow(0 0 3px rgba(0,212,255,0.2)); }
    50% { opacity: 0.8; filter: drop-shadow(0 0 10px rgba(0,212,255,0.6)); }
  }
  @keyframes coreGlow {
    0%, 100% { r: 8; opacity: 0.3; }
    50% { r: 12; opacity: 0.15; }
  }
  @keyframes wave {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-12deg); }
    75% { transform: rotate(12deg); }
  }
  @keyframes headTilt {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(4deg); }
  }
  @keyframes lookLeft {
    0%, 40%, 100% { transform: translateX(0); }
    15% { transform: translateX(-2px); }
    30% { transform: translateX(3px); }
  }
  @keyframes scanDown {
    0% { transform: translateY(-20px); opacity: 0; }
    15% { opacity: 0.6; }
    85% { opacity: 0.6; }
    100% { transform: translateY(50px); opacity: 0; }
  }
  @keyframes flicker {
    0%, 93%, 100% { opacity: 0.5; }
    94% { opacity: 0; }
    95% { opacity: 0.5; }
    96% { opacity: 0.1; }
    97% { opacity: 0.5; }
  }
  @keyframes spark {
    0%, 100% { opacity: 0; transform: scale(0.5); }
    50% { opacity: 1; transform: scale(1); }
  }
  @keyframes glitch {
    0%, 88%, 100% { transform: translate(0); }
    90% { transform: translate(-3px, 1px); }
    92% { transform: translate(3px, -1px); }
    94% { transform: translate(-1px, -2px); }
    96% { transform: translate(2px, 1px); }
  }

  /* ===== POSE: IDLE ===== */
  .pose-idle .timito-group { animation: float 4s ease-in-out infinite; }
  .pose-idle .eyes { animation: eyePulse 3s ease-in-out infinite; }
  .pose-idle .core-glow { animation: coreGlow 3s ease-in-out infinite; }
  .pose-idle .core-dot { animation: corePulse 2.5s ease-in-out infinite; }

  /* ===== POSE: CROSSED ===== */
  .pose-crossed .timito-group { animation: float 5s ease-in-out infinite; }
  .pose-crossed .eyes { animation: eyePulse 2.5s ease-in-out infinite; }
  .pose-crossed .core-dot { animation: corePulse 3s ease-in-out infinite; }
  .pose-crossed:hover .timito-group { animation: glitch 0.4s ease infinite; }

  /* ===== POSE: POINTING ===== */
  .pose-pointing .timito-group { animation: float 4.5s ease-in-out infinite; }
  .pose-pointing .head { animation: headTilt 5s ease-in-out infinite; transform-origin: 100px 75px; }
  .pose-pointing .scan-beam { animation: scanDown 2.5s linear infinite; }
  .pose-pointing .core-dot { animation: corePulse 2s ease-in-out infinite; }

  /* ===== POSE: WAVING ===== */
  .pose-waving .timito-group { animation: float 3.5s ease-in-out infinite; }
  .pose-waving .arm-right { animation: wave 1.2s ease-in-out infinite; transform-origin: 135px 130px; }
  .pose-waving .antenna-tip { animation: corePulse 1s ease-in-out infinite; }
  .pose-waving .eyes { animation: eyePulse 1.5s ease-in-out infinite; }

  /* ===== POSE: THINKING ===== */
  .pose-thinking .timito-group { animation: float 5s ease-in-out infinite; }
  .pose-thinking .pupils { animation: lookLeft 4s ease-in-out infinite; }
  .pose-thinking .core-dot { animation: corePulse 2s ease-in-out infinite; }

  /* ===== POSE: BROKEN ===== */
  .pose-broken .timito-group { animation: float 6s ease-in-out infinite; filter: saturate(0.3); }
  .pose-broken .core-dot { animation: flicker 2.5s ease-in-out infinite; }
  .pose-broken .spark1 { animation: spark 1.5s ease-in-out infinite; }
  .pose-broken .spark2 { animation: spark 2s ease-in-out infinite 0.5s; }
  .pose-broken .spark3 { animation: spark 1.8s ease-in-out infinite 1s; }

  /* ===== HOVER EFFECTS ===== */
  .timito-mascot:hover .eyes {
    opacity: 1 !important;
    filter: drop-shadow(0 0 8px rgba(0,212,255,0.8));
    transition: filter 0.2s;
  }
  .timito-mascot:hover .core-dot {
    opacity: 1 !important;
    filter: drop-shadow(0 0 12px rgba(0,212,255,0.8)) !important;
  }
  .pose-broken:hover .eyes {
    filter: drop-shadow(0 0 8px rgba(255,45,120,0.8));
  }
  .pose-broken:hover .core-dot {
    filter: drop-shadow(0 0 12px rgba(255,45,120,0.8)) !important;
  }
  .timito-mascot:hover .timito-svg {
    filter: drop-shadow(0 0 20px rgba(0,212,255,0.2))
            drop-shadow(0 0 50px rgba(0,212,255,0.1));
    transition: filter 0.3s ease;
  }
  .pose-broken:hover .timito-svg {
    filter: drop-shadow(0 0 20px rgba(255,45,120,0.15))
            drop-shadow(0 0 50px rgba(255,45,120,0.08));
  }
</style>
