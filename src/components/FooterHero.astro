---
/**
 * FooterHero.astro
 * Large typographic brand statement placed above the footer.
 * "PERFORMANCE. TRACKING. DESIGN." in oversized display text
 * with a CTA pill link.
 */
import SplitWords from './SplitWords.astro';
---

<section class="footer-hero" aria-hidden="true">
  <div class="container footer-hero__inner">
    <p class="footer-hero__display headline-reveal">
      <span class="h-line footer-hero__line footer-hero__line--glow" style="overflow:hidden"><SplitWords text="PERFORMANCE." /></span>
      <span class="h-line footer-hero__line footer-hero__line--outline" style="overflow:hidden"><SplitWords text="TRACKING." /></span>
      <span class="h-line footer-hero__line footer-hero__line--glow" style="overflow:hidden"><SplitWords text="DESIGN." /></span>
    </p>
    <a href="#kontakt" class="footer-hero__cta" data-magnetic>→ Gespräch anfragen</a>
  </div>
</section>

<style>
  /* ------------------------------------------------------------------
     Section wrapper
     ------------------------------------------------------------------ */
  .footer-hero {
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--border);
    background: var(--bg-primary);
    padding-block: clamp(4rem, 8vh, 7rem);
  }

  .footer-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: left;
  }

  /* ------------------------------------------------------------------
     Display type
     ------------------------------------------------------------------ */
  .footer-hero__display {
    font: 800 clamp(1.75rem, 5vw, 5.5rem)/0.95 'Unbounded', system-ui, sans-serif;
    letter-spacing: -0.04em;
    margin: 0;
    width: 100%;
  }

  .footer-hero__line {
    display: block;
    white-space: nowrap;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    cursor: default;
  }

  .footer-hero__line:hover {
    transform: scaleX(1.05);
  }

  /* Cyan glow lines */
  .footer-hero__line--glow {
    color: var(--accent-cyan);
    text-shadow:
      0 0 20px rgba(0, 212, 255, 0.45),
      0 0 60px rgba(0, 212, 255, 0.15);
  }

  /* Outline / stroke line */
  .footer-hero__line--outline {
    color: transparent;
    -webkit-text-stroke: 1.5px var(--text-primary);
  }

  /* ------------------------------------------------------------------
     CTA pill button
     ------------------------------------------------------------------ */
  .footer-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 3rem;
    padding: 1rem 2.5rem;
    border: none;
    border-radius: 999px;
    background: var(--accent-pink);
    color: #fff;
    font: 500 1rem/1 var(--font-body);
    text-decoration: none;
    transition: all var(--duration) var(--ease);
  }

  .footer-hero__cta:hover {
    background: var(--accent-pink);
    color: #fff;
    box-shadow: 0 0 30px rgba(255, 45, 120, 0.4);
    transform: translateY(-2px);
  }

  @media (max-width: 639px) {
    .footer-hero__display {
      font-size: clamp(1.25rem, 5vw, 2rem);
      letter-spacing: -0.04em;
    }
    .footer-hero__line:hover {
      transform: none;
    }
  }
</style>
