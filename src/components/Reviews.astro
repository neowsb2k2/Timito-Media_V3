---
import SplitWords from './SplitWords.astro';
---

<section class="section reviews">
  <div class="container">
    <div class="reviews__header reveal">
      <!-- Google logo inline SVG (simplified G logo) -->
      <div class="reviews__google">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <div class="reviews__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <span class="reviews__rating">5.0 &middot; Google Reviews</span>
      </div>
    </div>

    <h2 class="giant-title headline-reveal">
      <span class="h-line" style="overflow:hidden"><SplitWords text="Was Kunden" /></span>
      <span class="h-line line-accent" style="overflow:hidden"><SplitWords text="sagen." /></span>
    </h2>

    <div class="reviews__grid">
      <!-- Real review -->
      <div class="reviews__card reveal">
        <div class="reviews__card-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="reviews__card-text">"Ich bin Komplett Kunde von Timito-Media da ich zu 100% überzeugt bin von der Arbeit. Christina und Mike haben unser gesamtes Google Ads Setup transformiert und die Ergebnisse sprechen für sich."</p>
        <div class="reviews__card-author">
          <div class="reviews__card-avatar">MS</div>
          <div>
            <span class="reviews__card-name">Michael Schwarz</span>
            <span class="reviews__card-date">Google Review</span>
          </div>
        </div>
      </div>

    </div>

    <div class="reviews__link reveal">
      <a href="https://g.page/timito-media/review" target="_blank" rel="noopener noreferrer">
        Alle Google Reviews ansehen &#8599;
      </a>
    </div>
  </div>
</section>

<style>
  .reviews {
    position: relative;
    overflow: hidden;
    z-index: 10;
    background: var(--bg-primary);
  }

  .reviews__header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .reviews__google {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.75rem;
    background: rgba(255,255,255,0.03);
    border-radius: 100px;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .reviews__stars {
    color: var(--accent-yellow);
    font-size: 1.25rem;
  }

  .reviews__rating {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .reviews__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
    max-width: 540px;
  }

  .reviews__card {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: border-color var(--duration) var(--ease), box-shadow var(--duration) var(--ease);
  }
  .reviews__card:hover {
    border-color: rgba(0,212,255,0.3);
    box-shadow: 0 0 20px rgba(0,212,255,0.12), 0 0 50px rgba(0,212,255,0.05);
  }

  .reviews__card-stars {
    color: var(--accent-yellow);
    margin-bottom: 1rem;
  }

  .reviews__card-text {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  .reviews__card-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .reviews__card-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: transparent;
    border: 1.5px solid var(--accent-cyan);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent-cyan);
    box-shadow: 0 0 10px rgba(0,212,255,0.15);
  }

  .reviews__card-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    display: block;
  }

  .reviews__card-date {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .reviews__link {
    text-align: center;
  }

  .reviews__link a {
    color: var(--accent-cyan);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .reviews__link a:hover {
    text-decoration: underline;
  }

</style>
