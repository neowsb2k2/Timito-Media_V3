---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  readTime: string;
  publishDate: Date;
  cover?: ImageMetadata;
}

const { title, description, slug, category, readTime, publishDate, cover } = Astro.props;

const categoryColorMap: Record<string, string> = {
  Tracking: '5, 223, 114',
  'Google Ads': '0, 212, 255',
  'Social Ads': '255, 45, 120',
  Webdesign: '255, 214, 0',
  Strategie: '168, 85, 247',
};

const rgb = categoryColorMap[category] || '0, 212, 255';
---

<a href={`/blog/${slug}`} class="blog-card reveal" style={`--cat: ${rgb};`}>
  <div class="blog-card__image" aria-label={`Cover für: ${title}`}>
    {cover && <Image src={cover} alt={title} width={480} class="blog-card__cover-img" />}
    <span class="blog-card__category">{category}</span>
  </div>
  <div class="blog-card__body">
    <span class="blog-card__badge">{category}</span>
    <h3 class="blog-card__title">{title}</h3>
    <p class="blog-card__excerpt">{description}</p>
    <div class="blog-card__meta">
      <span>{readTime} Lesezeit</span>
      <span>{new Date(publishDate).toLocaleDateString('de-AT', { day: '2-digit', month: 'short', year: 'numeric' })}</span>
    </div>
  </div>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--border);
    border-top: 2px solid rgba(var(--cat), 0.5);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      transform var(--duration) var(--ease),
      border-color var(--duration) var(--ease),
      box-shadow 0.4s ease;
  }

  .blog-card:hover {
    transform: translateY(-2px);
    border-color: rgba(var(--cat), 0.35);
    border-top-color: rgb(var(--cat));
    box-shadow:
      0 0 20px rgba(var(--cat), 0.1),
      0 0 50px rgba(var(--cat), 0.04);
  }

  .blog-card__image {
    height: 180px;
    background:
      linear-gradient(135deg, rgba(var(--cat), 0.08), transparent 60%),
      linear-gradient(135deg, var(--bg-surface), var(--bg-card-hover));
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    overflow: hidden;
  }

  .blog-card__cover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-card__category {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.75rem;
    background: rgba(var(--cat), 0.1);
    border: 1px solid rgba(var(--cat), 0.25);
    border-radius: 999px;
    color: rgb(var(--cat));
    box-shadow: 0 0 8px rgba(var(--cat), 0.1);
  }

  .blog-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .blog-card__badge {
    font: 600 0.65rem/1 var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.7rem;
    background: rgba(var(--cat), 0.1);
    border: 1px solid rgba(var(--cat), 0.2);
    border-radius: 999px;
    color: rgb(var(--cat));
    width: fit-content;
    margin-bottom: 0.75rem;
  }

  .blog-card__title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .blog-card__excerpt {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-primary);
    font-family: var(--font-mono);
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
</style>
