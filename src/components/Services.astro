---
/**
 * Services.astro
 * Accordion layout for the six core services.
 * Data from src/data/services.ts — smooth height animation,
 * per-color accents, staggered content reveal.
 */
import SectionLabel from './SectionLabel.astro';
import SplitWords from './SplitWords.astro';
import { services } from '../data/services';

const titleMap: Record<string, string> = {
  'Server-Side Tracking': 'Server-Side<br>Tracking',
  'Google Ads': 'Google Ads',
  'Social Ads': 'Social Ads',
  'Webdesign & Entwicklung': 'Full-Stack<br>Webdesign',
  'UI/UX Design': 'UI/UX Design',
  'Strategie & Beratung': 'Strategie &amp;<br>Beratung',
};

const ctaMap: Record<string, string> = {
  'Server-Side Tracking': 'Tracking Audit anfragen',
  'Google Ads': 'Kampagnen starten',
  'Social Ads': 'Social Ads starten',
  'Webdesign & Entwicklung': 'Relaunch anfragen',
  'Strategie & Beratung': 'Strategiegespräch buchen',
};
---

<section id="leistungen" class="section services">
  <div class="services__watermark" aria-hidden="true">LEISTUNGEN</div>
  <div class="container">
    <SectionLabel text="Unsere Leistungen" />
    <h2 class="services__title" data-split-reveal style="overflow:hidden"><SplitWords text="Alles was du brauchst. Nichts was du nicht brauchst." gap="0.28em" /></h2>

    <div class="acc" id="servicesAccordion">
      {services.map((service, i) => (
        <div class="acc-item" data-color={service.color}>
          <div class="acc-header" role="button" tabindex="0" aria-expanded="false">
            <span class="acc-num">/{String(i + 1).padStart(2, '0')}</span>
            <h3 class="acc-title" set:html={titleMap[service.name] || service.name} />
            <span class="acc-tagline">{service.tagline}</span>
            <span class="acc-toggle" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9l6 6 6-6" />
              </svg>
            </span>
          </div>

          <div class="acc-panel">
            <div>
              <div class="acc-panel__inner">
                <div class="acc-panel__spacer"></div>
                <div class="acc-panel__left">
                  <div class="acc-ctas">
                    <a href="#kontakt" class="btn-accent btn-accent--fill">
                      {ctaMap[service.name]} <span aria-hidden="true">&nearr;</span>
                    </a>
                    <a href={`/leistungen/${service.slug}`} class="btn-accent btn-accent--outline">
                      Details ansehen <span aria-hidden="true">&nearr;</span>
                    </a>
                  </div>
                </div>
                <div class="acc-panel__right">
                  <ul class="acc-features">
                    {service.features.map((f) => (
                      <li>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M9 18l6-6-6-6" />
                        </svg>
                        {f}
                      </li>
                    ))}
                  </ul>
                  <div class="acc-proof">
                    <span class="acc-proof__num">{service.proofNum}</span>
                    <span class="acc-proof__label">{service.proofLabel}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  (function () {
    const accordion = document.getElementById('servicesAccordion');
    if (!accordion) return;
    const items = accordion.querySelectorAll('.acc-item');

    function toggle(item) {
      const isOpen = item.classList.contains('is-open');
      items.forEach(i => {
        i.classList.remove('is-open');
        i.querySelector('.acc-header')?.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('is-open');
        item.querySelector('.acc-header')?.setAttribute('aria-expanded', 'true');
      }
    }

    items.forEach(item => {
      const header = item.querySelector('.acc-header');
      if (!header) return;
      header.addEventListener('click', () => toggle(item));
      header.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          toggle(item);
        }
      });
    });

    // Hover to open on desktop
    const isDesktop = window.matchMedia('(hover: hover) and (pointer: fine)');
    if (isDesktop.matches) {
      items.forEach(item => {
        item.addEventListener('mouseenter', () => toggle(item));
      });

      // Glow follows cursor inside card
      items.forEach(item => {
        item.addEventListener('mousemove', (e) => {
          const rect = item.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / rect.width) * 100;
          const y = ((e.clientY - rect.top) / rect.height) * 100;
          item.style.setProperty('--glow-x', x + '%');
          item.style.setProperty('--glow-y', y + '%');
        });
      });
    }
  })();
</script>

<style>
  /* ===== SECTION ===== */
  .services {
    position: relative;
    overflow: hidden;
  }

  .services__watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font: 900 clamp(6rem, 18vw, 16rem)/1 'Unbounded', sans-serif;
    color: rgba(255, 255, 255, 0.015);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .services :global(.container) {
    position: relative;
    z-index: 1;
  }

  .services__title {
    margin-bottom: 3rem;
  }

  /* ===== COLOR MAPPING ===== */
  .acc-item[data-color="green"]  { --c: 5, 223, 114;   --c-text: #000; }
  .acc-item[data-color="cyan"]   { --c: 0, 212, 255;   --c-text: #000; }
  .acc-item[data-color="pink"]   { --c: 255, 45, 120;  --c-text: #fff; }
  .acc-item[data-color="yellow"] { --c: 255, 214, 0;    --c-text: #000; }
  .acc-item[data-color="orange"] { --c: 255, 140, 66;  --c-text: #000; }
  .acc-item[data-color="purple"] { --c: 168, 85, 247;  --c-text: #fff; }

  /* ===== ACCORDION ITEM ===== */
  .acc-item {
    position: relative;
    border: 1px solid transparent;
    border-top-color: var(--border);
    border-radius: 12px;
    transition: all 0.45s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* ===== HOVER GLOW EFFECT ===== */
  .acc-item::after {
    content: '';
    position: absolute;
    top: -1px;
    left: -1px;
    right: -1px;
    bottom: -1px;
    border-radius: 12px;
    opacity: 0;
    transition: opacity 0.45s ease;
    pointer-events: none;
    z-index: -1;
    background: radial-gradient(
      ellipse 300px 200px at var(--glow-x, 50%) var(--glow-y, 50%),
      rgba(var(--c), 0.08),
      transparent
    );
  }

  .acc-item:hover::after {
    opacity: 1;
  }

  .acc-item:last-child {
    border-bottom-color: var(--border);
  }

  /* ===== ITEM OPEN STATE ===== */
  .acc-item.is-open {
    border-color: rgba(var(--c), 0.35);
    box-shadow: 0 0 25px rgba(var(--c), 0.08), inset 0 0 60px rgba(var(--c), 0.03);
    background: rgba(var(--c), 0.03);
  }

  /* ===== HEADER ===== */
  .acc-header {
    display: grid;
    grid-template-columns: 80px 1fr auto auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
    cursor: pointer;
    user-select: none;
  }

  .acc-header:focus-visible {
    outline: 2px solid var(--accent-cyan);
    outline-offset: -2px;
    border-radius: 12px;
  }

  /* Number */
  .acc-num {
    font: 500 1rem/1 var(--font-mono);
    color: var(--text-muted);
    transition: color 0.35s ease, transform 0.35s ease;
  }

  .acc-item.is-open .acc-num {
    color: rgb(var(--c));
    transform: scale(1.1);
  }

  /* Title */
  .acc-title {
    font: 800 clamp(1.3rem, 3vw, 2rem)/1.1 'Unbounded', sans-serif;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    transition: color 0.35s ease, transform 0.35s ease, text-shadow 0.35s ease;
    margin: 0;
  }

  .acc-header:hover .acc-title {
    color: var(--text-primary);
  }

  .acc-item.is-open .acc-title {
    color: var(--text-primary);
    transform: translateX(4px);
    text-shadow: 0 0 20px rgba(var(--c), 0.15);
  }

  /* Tagline */
  .acc-tagline {
    font-size: 0.8rem;
    color: var(--text-muted);
    max-width: 220px;
    text-align: right;
    line-height: 1.5;
    transition: color 0.35s ease;
  }

  .acc-item.is-open .acc-tagline {
    color: var(--text-secondary);
  }

  /* Toggle */
  .acc-toggle {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-muted);
    transition: all 0.35s ease;
  }

  .acc-toggle svg {
    display: block;
    transition: transform 0.35s ease;
  }

  .acc-item.is-open .acc-toggle {
    color: rgb(var(--c));
    border-color: rgba(var(--c), 0.3);
    background: rgba(var(--c), 0.06);
    box-shadow: 0 0 10px rgba(var(--c), 0.1);
  }

  .acc-item.is-open .acc-toggle svg {
    transform: rotate(180deg);
  }

  /* ===== PANEL ===== */
  .acc-panel {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.55s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .acc-item.is-open .acc-panel {
    grid-template-rows: 1fr;
  }

  .acc-panel > div {
    overflow: hidden;
  }

  .acc-panel__inner {
    display: grid;
    grid-template-columns: 80px 1fr 1fr;
    gap: 1.5rem;
    padding: 0 2rem 2rem;
    align-items: start;
  }

  .acc-panel__spacer {
    /* Alignment spacer — matches header number column width */
  }

  /* ===== PANEL LEFT (CTAs) ===== */
  .acc-panel__left {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .acc-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* ===== ACCENT BUTTONS ===== */
  .btn-accent {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .btn-accent--fill {
    background: rgb(var(--c));
    color: var(--c-text);
    border: none;
    box-shadow: 0 0 15px rgba(var(--c), 0.2);
  }

  .btn-accent--fill:hover {
    box-shadow: 0 0 25px rgba(var(--c), 0.35);
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .btn-accent--outline {
    background: transparent;
    border: 1.5px solid rgba(var(--c), 0.4);
    color: rgb(var(--c));
  }

  .btn-accent--outline:hover {
    background: rgba(var(--c), 0.06);
    border-color: rgba(var(--c), 0.6);
    transform: translateY(-1px);
  }

  /* ===== FEATURES LIST ===== */
  .acc-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .acc-features li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .acc-features li svg {
    color: rgb(var(--c));
    flex-shrink: 0;
  }

  /* ===== PROOF STAT BAR ===== */
  .acc-proof {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-top: 1.25rem;
    padding: 0.75rem 1rem;
    background: rgba(var(--c), 0.06);
    border: 1px solid rgba(var(--c), 0.12);
    border-radius: 10px;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .acc-item.is-open .acc-proof {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.5s;
  }

  .acc-proof__num {
    font: 800 clamp(1.25rem, 2vw, 1.75rem)/1 var(--font-heading);
    color: rgb(var(--c));
    white-space: nowrap;
  }

  .acc-proof__label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  /* ===== STAGGERED CONTENT REVEAL ===== */
  .acc-panel__left,
  .acc-ctas,
  .acc-features {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .acc-features li {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  /* Reveal on open */
  .acc-item.is-open .acc-panel__left {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.15s;
  }

  .acc-item.is-open .acc-features {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.2s;
  }

  .acc-item.is-open .acc-features li:nth-child(1) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.22s;
  }

  .acc-item.is-open .acc-features li:nth-child(2) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.28s;
  }

  .acc-item.is-open .acc-features li:nth-child(3) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.34s;
  }

  .acc-item.is-open .acc-features li:nth-child(4) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.40s;
  }

  .acc-item.is-open .acc-features li:nth-child(5) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.46s;
  }

  .acc-item.is-open .acc-features li:nth-child(6) {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.52s;
  }

  .acc-item.is-open .acc-ctas {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.35s;
  }

  /* ===== RESPONSIVE (Tablet) ===== */
  @media (max-width: 900px) {
    .acc-header {
      grid-template-columns: 50px 1fr auto;
    }

    .acc-tagline {
      display: none;
    }

    .acc-panel__inner {
      grid-template-columns: 1fr;
    }

    .acc-panel__spacer {
      display: none;
    }

    .acc-title {
      font-size: clamp(1.1rem, 4vw, 1.6rem);
    }

    .acc-ctas {
      flex-direction: column;
    }

    .btn-accent {
      width: 100%;
      justify-content: center;
    }
  }

  /* ===== RESPONSIVE (Mobile) ===== */
  @media (max-width: 600px) {
    .acc-header {
      grid-template-columns: 40px 1fr auto;
      gap: 0.75rem;
      padding: 1.25rem 1rem;
    }

    .acc-panel__inner {
      padding: 0 1rem 1.5rem;
    }

    .acc-num {
      font-size: 0.9rem;
    }
  }
</style>
