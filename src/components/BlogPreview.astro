---
import BlogCard from './BlogCard.astro';
import SplitWords from './SplitWords.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 2);
---

<section class="section blog-preview">
  <div class="container">
    <h2 class="giant-title headline-reveal">
      <span class="h-line" style="overflow:hidden"><SplitWords text="Insights" /></span>
      <span class="h-line" style="overflow:hidden"><SplitWords text="aus der" /></span>
      <span class="h-line line-accent" style="overflow:hidden"><SplitWords text="Praxis." /></span>
    </h2>
    <p class="blog-preview__sub">Praxisnahe Guides aus 15 Jahren Performance Marketing.</p>
    <div class="blog-preview__grid reveal-stagger">
      {posts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          slug={post.slug}
          category={post.data.category}
          readTime={post.data.readTime}
          publishDate={post.data.publishDate}
        />
      ))}
    </div>
    <div class="blog-preview__link reveal">
      <a href="/blog">Alle Artikel lesen &rarr;</a>
    </div>
  </div>
</section>

<style>
  .blog-preview {
    position: relative;
    overflow: hidden;
  }

  .blog-preview__sub {
    color: var(--text-secondary);
    margin-bottom: 3rem;
    max-width: 500px;
  }

  .blog-preview__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .blog-preview__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-preview__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .blog-preview__link {
    text-align: center;
  }

  .blog-preview__link a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    border: 1px solid rgba(0,212,255,0.3);
    border-radius: 100px;
    color: var(--accent-cyan);
    font: 500 0.85rem/1 var(--font-body);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .blog-preview__link a:hover {
    background: rgba(0,212,255,0.08);
    border-color: var(--accent-cyan);
    box-shadow: 0 0 20px rgba(0,212,255,0.15);
    text-decoration: none;
  }

</style>
