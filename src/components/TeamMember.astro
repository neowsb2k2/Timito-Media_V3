---
interface Props {
  name: string;
  role: string;
  description: string;
  skills: string[];
  image: string;
}

const { name, role, description, skills, image } = Astro.props;
---

<div class="team-member reveal">
  <div class="team-member__avatar">
    <img src={image} alt={`${name}, ${role}`} width="100" height="100" class="team-member__photo" loading="lazy" decoding="async" />
  </div>
  <div class="team-member__info">
    <h3 class="team-member__name">{name}</h3>
    <p class="team-member__role">{role}</p>
    <p class="team-member__desc">{description}</p>
    <div class="team-member__skills">
      {skills.map((skill) => <span class="team-member__skill">{skill}</span>)}
    </div>
  </div>
</div>

<style>
  .team-member {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .team-member {
      grid-template-columns: 60px 1fr;
      gap: 1rem;
      padding: 1.25rem;
    }

    .team-member__photo {
      width: 60px;
      height: 60px;
    }

    .team-member__desc {
      display: none;
    }

    .team-member__skill {
      font-size: 12px;
    }
  }

  .team-member__photo {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    border: 2px solid var(--border);
  }

  .team-member__name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .team-member__role {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .team-member__desc {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .team-member__skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .team-member__skill {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 999px;
  }
</style>
