---
import { faqs } from '../data/faq';
import SplitWords from './SplitWords.astro';
---

<section id="faq" class="section faq">
  <div class="container">
    <h2 class="giant-title headline-reveal">
      <span class="h-line" style="overflow:hidden"><SplitWords text="FAQ" /></span>
      <span class="h-line line-accent" style="overflow:hidden"><SplitWords text="Häufige Fragen zur Zusammenarbeit." /></span>
    </h2>
    <div class="faq__list" id="faqAccordion">
      {faqs.map((faq, i) => (
        <div class="faq__item reveal">
          <button
            class="faq__trigger"
            type="button"
            aria-expanded="false"
            aria-controls={`faq-panel-${i}`}
          >
            <span class="faq__num">/{String(i + 1).padStart(2, '0')}</span>
            <span class="faq__question">{faq.question}</span>
            <span class="faq__toggle" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9l6 6 6-6" />
              </svg>
            </span>
          </button>
          <div class="faq__panel" id={`faq-panel-${i}`}>
            <div>
              <div class="faq__answer">
                <p>{faq.answer}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  (function () {
    const accordion = document.getElementById('faqAccordion');
    if (!accordion) return;
    const items = accordion.querySelectorAll('.faq__item');

    function toggle(item) {
      const isOpen = item.classList.contains('is-open');
      // Close all
      items.forEach(i => {
        i.classList.remove('is-open');
        i.querySelector('.faq__trigger')?.setAttribute('aria-expanded', 'false');
      });
      // Open clicked (if was closed)
      if (!isOpen) {
        item.classList.add('is-open');
        item.querySelector('.faq__trigger')?.setAttribute('aria-expanded', 'true');
      }
    }

    items.forEach(item => {
      const trigger = item.querySelector('.faq__trigger');
      if (!trigger) return;
      trigger.addEventListener('click', () => toggle(item));
    });
  })();
</script>

<style>
  .faq {
    position: relative;
    overflow: hidden;
  }

  .faq__list {
    max-width: 900px;
    margin-inline: auto;
  }

  /* ===== ITEM ===== */
  .faq__item {
    border: 1px solid transparent;
    border-top-color: var(--border);
    border-radius: 12px;
    transition: all 0.45s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .faq__item:last-child {
    border-bottom-color: var(--border);
  }

  .faq__item.is-open {
    border-color: rgba(0, 212, 255, 0.35);
    background: rgba(0, 212, 255, 0.04);
    box-shadow: 0 0 25px rgba(0, 212, 255, 0.15), 0 0 60px rgba(0, 212, 255, 0.06), inset 0 0 40px rgba(0, 212, 255, 0.03);
  }

  /* ===== TRIGGER ===== */
  .faq__trigger {
    display: grid;
    grid-template-columns: 50px 1fr auto;
    align-items: center;
    gap: 1rem;
    width: 100%;
    padding: 1.25rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: inherit;
    font: inherit;
  }

  .faq__trigger:focus-visible {
    outline: 2px solid var(--accent-cyan);
    outline-offset: -2px;
    border-radius: 12px;
  }

  /* Number */
  .faq__num {
    font: 500 0.875rem/1 var(--font-mono);
    color: var(--text-muted);
    transition: color 0.35s ease;
  }

  .faq__item.is-open .faq__num {
    color: var(--accent-cyan);
  }

  /* Question text */
  .faq__question {
    font: 600 1rem/1.4 var(--font-body);
    color: var(--text-secondary);
    transition: color 0.35s ease;
    text-align: left;
  }

  .faq__trigger:hover .faq__question {
    color: var(--text-primary);
  }

  .faq__item.is-open .faq__question {
    color: var(--text-primary);
  }

  /* Toggle icon */
  .faq__toggle {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-muted);
    transition: all 0.35s ease;
    flex-shrink: 0;
  }

  .faq__toggle svg {
    display: block;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .faq__item.is-open .faq__toggle {
    color: var(--accent-cyan);
    border-color: rgba(0, 212, 255, 0.3);
    background: rgba(0, 212, 255, 0.06);
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.1);
  }

  .faq__item.is-open .faq__toggle svg {
    transform: rotate(180deg);
  }

  /* ===== PANEL — smooth height via grid ===== */
  .faq__panel {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .faq__item.is-open .faq__panel {
    grid-template-rows: 1fr;
  }

  .faq__panel > div {
    overflow: hidden;
  }

  /* ===== ANSWER ===== */
  .faq__answer {
    padding: 0 1.5rem 1.5rem;
    padding-left: calc(50px + 1rem + 1.5rem);
  }

  .faq__answer p {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
    max-width: 600px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease 0.1s, transform 0.4s ease 0.1s;
  }

  .faq__item.is-open .faq__answer p {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 639px) {
    .faq__trigger {
      grid-template-columns: 1fr auto;
      gap: 0.75rem;
      padding: 1rem;
    }

    .faq__num {
      display: none;
    }

    .faq__question {
      font-size: 0.9375rem;
    }

    .faq__toggle {
      width: 28px;
      height: 28px;
    }

    .faq__toggle svg {
      width: 14px;
      height: 14px;
    }

    .faq__answer {
      padding: 0 1rem 1.25rem;
    }
  }
</style>
